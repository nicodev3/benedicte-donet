---
import { getCollection, render } from "astro:content";
import PageLayout from "@/layouts/PageLayout.astro";
import BlogPostLayout from "@/layouts/BlogPostLayout.astro";
import type { CollectionEntry } from "astro:content";
import { getContentSlug, getLocaleFromFilePath, localizedPath } from "@/lib/i18n";

/**
 * Sur le site WordPress d'origine, les articles de blog sont servis
 * à la racine (/mon-article/), comme les pages. Cette route reproduit
 * ce comportement pour préserver toutes les URLs indexées.
 */
export async function getStaticPaths() {
  const staticPageSlugs = new Set(["masterclass"]);
  const pages = (await getCollection("pages", ({ data }) => !data.draft)).filter(
    (page) => !staticPageSlugs.has(getContentSlug(page.filePath, page.id))
  );
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const localizedSlug = (entry: (typeof pages)[number] | (typeof posts)[number]) => {
    const locale = getLocaleFromFilePath(entry.filePath);
    const slug = getContentSlug(entry.filePath, entry.id);
    const path = localizedPath(`/${slug}/`, locale);
    return path === "/" ? "" : path.replace(/^\/|\/$/g, "");
  };

  return [
    ...pages.map((page) => ({
      params: {
        slug: localizedSlug(page),
      },
      props: { type: "page" as const, entry: page },
    })),
    ...posts.map((post) => ({
      params: {
        slug: localizedSlug(post),
      },
      props: { type: "post" as const, entry: post },
    })),
  ];
}

type Props =
  | { type: "page"; entry: CollectionEntry<"pages"> }
  | { type: "post"; entry: CollectionEntry<"blog"> };

const { type, entry } = Astro.props;
const { Content } = await render(entry);
---

{
  type === "page" ? (
    <PageLayout page={entry}>
      <Content />
    </PageLayout>
  ) : (
    <BlogPostLayout post={entry}>
      <Content />
    </BlogPostLayout>
  )
}
