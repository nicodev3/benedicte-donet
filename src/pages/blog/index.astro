---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/common/Container.astro";
import Section from "@/components/common/Section.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("fr-FR", { dateStyle: "long" }).format(date);
---

<BaseLayout
  title="Blog"
  description="Articles de psychologie par Bénédicte Donet : trauma, EMDR, méditation, anxiété, relation au corps et bien plus."
>
  <Section tone="soft" class="blog-hero">
    <Container narrow>
      <h1>Le blog</h1>
      <p>
        Des articles pour mieux te comprendre : trauma, EMDR, méditation,
        anxiété, relation au corps.
      </p>
    </Container>
  </Section>

  <Container>
    <div class="posts-grid">
      {
        posts.map((post) => (
          <article class="post-card">
            {post.data.image && (
              <a href={`/${post.id}/`} tabindex="-1" aria-hidden="true">
                <img
                  src={post.data.image}
                  alt=""
                  loading="lazy"
                  width="400"
                  height="260"
                />
              </a>
            )}
            <div class="post-card-body">
              <time datetime={post.data.date.toISOString()}>
                {formatDate(post.data.date)}
              </time>
              <h2>
                <a href={`/${post.id}/`}>{post.data.title}</a>
              </h2>
              {post.data.excerpt && <p>{post.data.excerpt}</p>}
              <a href={`/${post.id}/`} class="post-card-link">
                Lire l'article →
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </Container>
</BaseLayout>

<style>
  .blog-hero {
    padding-block: var(--space-xl);
    text-align: center;
  }

  .blog-hero p {
    margin-top: var(--space-sm);
    color: var(--color-text-soft);
    font-size: var(--text-lg);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-lg);
    padding-block: var(--space-xl);
  }

  .post-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .post-card:hover {
    box-shadow: var(--shadow-soft);
    transform: translateY(-3px);
  }

  .post-card img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .post-card-body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }

  .post-card-body time {
    font-size: var(--text-sm);
    color: var(--color-text-soft);
  }

  .post-card-body h2 {
    font-size: var(--text-xl);
  }

  .post-card-body h2 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .post-card-body h2 a:hover {
    color: var(--color-primary);
  }

  .post-card-body p {
    color: var(--color-text-soft);
    font-size: var(--text-sm);
    flex: 1;
  }

  .post-card-link {
    font-family: var(--font-heading);
    font-weight: 700;
    text-decoration: none;
  }
</style>
