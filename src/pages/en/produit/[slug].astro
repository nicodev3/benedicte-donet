---
import { render } from "astro:content";
import ProductLayout from "@/layouts/ProductLayout.astro";
import OptimizedContent from "@/components/common/OptimizedContent.astro";
import { getProductStaticPaths } from "@/lib/products";

export async function getStaticPaths() {
  return getProductStaticPaths("en");
}

const { product } = Astro.props;
const { Content } = await render(product);
---

<ProductLayout product={product}>
  <OptimizedContent Content={Content} eagerFirst={false} sizes="(max-width: 768px) 100vw, 640px" />
</ProductLayout>
