---
import BaseLayout from "./BaseLayout.astro";
import Container from "@/components/common/Container.astro";
import Section from "@/components/common/Section.astro";
import SiteImage from "@/components/common/SiteImage.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import { buildBreadcrumbs } from "@/lib/breadcrumbs";
import { getNavigationSettings } from "@/lib/settings";
import { getLocaleFromPath } from "@/lib/i18n";
import type { CollectionEntry } from "astro:content";

interface Props {
  page: CollectionEntry<"pages">;
}

const { page } = Astro.props;
const { title, description, image, imageAlt, seoTitle, seoDescription } =
  page.data;

const locale = getLocaleFromPath(Astro.url.pathname);
const navigation = await getNavigationSettings(locale);
const breadcrumbs = buildBreadcrumbs(
  Astro.url.pathname,
  title,
  navigation,
  undefined,
  locale
);
---

<BaseLayout
  title={seoTitle || title}
  description={seoDescription || description}
  image={image}
>
  <Section tone="soft" class="page-hero">
    <Container narrow>
      <Breadcrumb items={breadcrumbs} />
      <h1>{title}</h1>
      {description && <p class="page-description">{description}</p>}
    </Container>
  </Section>

  {
    image && (
      <Container narrow>
        <SiteImage
          src={image}
          alt={imageAlt || title}
          class="page-image"
          width={1400}
          widths={[600, 900, 1400]}
          sizes="(max-width: 800px) 100vw, 736px"
          loading="eager"
          fetchpriority="high"
        />
      </Container>
    )
  }

  <Container>
    <article class="prose">
      <slot />
    </article>
  </Container>
</BaseLayout>

<style>
  .page-hero {
    padding-block: var(--space-xl);
    text-align: center;
  }

  .page-description {
    margin-top: var(--space-sm);
    font-size: var(--text-lg);
    color: var(--color-text-soft);
  }

  .page-image {
    border-radius: var(--radius-md);
    margin-block: var(--space-lg);
    box-shadow: var(--shadow-soft);
  }

  article {
    padding-block: var(--space-lg) var(--space-xl);
  }
</style>
