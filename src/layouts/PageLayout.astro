---
import BaseLayout from "./BaseLayout.astro";
import Container from "@/components/common/Container.astro";
import Section from "@/components/common/Section.astro";
import Hero from "@/components/sections/Hero.astro";
import ServicesHero from "@/components/sections/ServicesHero.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import PhotoGalleryEnhancer from "@/components/common/PhotoGalleryEnhancer.astro";
import PageIntroEnhancer from "@/components/common/PageIntroEnhancer.astro";
import PageCtaEnhancer from "@/components/common/PageCtaEnhancer.astro";
import AboutImageSplitEnhancer from "@/components/common/AboutImageSplitEnhancer.astro";
import ProseQuoteEnhancer from "@/components/common/ProseQuoteEnhancer.astro";
import PsychotherapieApproachEnhancer from "@/components/common/PsychotherapieApproachEnhancer.astro";
import PsychotherapieSpecialitesEnhancer from "@/components/common/PsychotherapieSpecialitesEnhancer.astro";
import PsychotherapieTarifEnhancer from "@/components/common/PsychotherapieTarifEnhancer.astro";
import ServicesHeroEnhancer from "@/components/common/ServicesHeroEnhancer.astro";
import ServicesIntroEnhancer from "@/components/common/ServicesIntroEnhancer.astro";
import ServicesFaqEnhancer from "@/components/common/ServicesFaqEnhancer.astro";
import ServicesSectionsEnhancer from "@/components/common/ServicesSectionsEnhancer.astro";
import ServicesMediaEnhancer from "@/components/common/ServicesMediaEnhancer.astro";
import PhotoOffersEnhancer from "@/components/common/PhotoOffersEnhancer.astro";
import PhotoProcessEnhancer from "@/components/common/PhotoProcessEnhancer.astro";
import PhotoTestimonialsEnhancer from "@/components/common/PhotoTestimonialsEnhancer.astro";
import InfosPratiquesBookingEnhancer from "@/components/common/InfosPratiquesBookingEnhancer.astro";
import InfosPratiquesNotesEnhancer from "@/components/common/InfosPratiquesNotesEnhancer.astro";
import ReviewsBlock from "@/components/sections/ReviewsBlock.astro";
import RelatedPostsCarousel from "@/components/sections/RelatedPostsCarousel.astro";
import { getLatestPosts } from "@/lib/blog";
import { getCollection } from "astro:content";
import { SITE } from "@/site.config";
import {
  buildBreadcrumbStructuredData,
  buildBreadcrumbs,
} from "@/lib/breadcrumbs";
import { getHomeSettings } from "@/lib/settings";
import { getNavigationItems } from "@/lib/navigation";
import { getContentSlug, getLocaleFromPath } from "@/lib/i18n";
import { useTranslations } from "@/lib/translations";
import { getOptimizedImage } from "@/lib/images";
import type { CollectionEntry } from "astro:content";

type StandardPageEntry = Omit<CollectionEntry<"pages">, "data"> & {
  data: Exclude<CollectionEntry<"pages">["data"], { pageType: "home" }>;
};

interface Props {
  page: StandardPageEntry;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { page, structuredData } = Astro.props;
const { title, heroTitle, description, image, seoTitle, seoDescription } = page.data;
const hasHero = Boolean(image);
const pageSlug = getContentSlug(page.filePath, page.id);
const lcpSource =
  pageSlug === "services" ? "/images/heroes/hero-services.jpg" : hasHero ? image : undefined;
const lcpImage = lcpSource
  ? await getOptimizedImage(lcpSource, {
      widths: [414, 640, 828],
      format: "webp",
      quality: 65,
    })
  : undefined;

const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const homeReviews =
  pageSlug === "infos-pratiques" ? (await getHomeSettings(locale)).reviews : null;
const journalPosts =
  pageSlug === "services"
    ? getLatestPosts(await getCollection("blog"), locale)
    : [];
const breadcrumbs = buildBreadcrumbs(
  Astro.url.pathname,
  title,
  getNavigationItems(locale),
  undefined,
  locale
);

function getServiceFaqStructuredData() {
  const questions =
    locale === "fr"
      ? [
          {
            name: "Suis-je la bonne psychologue pour vous ?",
            text: "Je vous invite à parcourir mon site et à prendre le temps de sentir si mon approche peut vous convenir. Mon approche est holistique et engagée, et toute question sur ma pratique ou mon cadre thérapeutique est bienvenue.",
          },
          {
            name: "Quelle est la régularité conseillée pour les séances ?",
            text: "Nous en discutons lors de la première séance. Le rythme dépend de votre capacité à recevoir, du temps d'intégration, de vos envies et de vos besoins.",
          },
          {
            name: "Pourquoi les séances durent 1 h 30 ?",
            text: "Ce format offre un espace suffisamment spacieux pour sentir, se déposer et partager sans précipiter le processus thérapeutique.",
          },
          {
            name: "Quel espace je propose ?",
            text: "Je propose un environnement accueillant, avec une écoute bienveillante et sereine, afin d'être présente et disponible lors de chaque séance.",
          },
        ]
      : [
          {
            name: "Am I the right psychologist for you?",
            text: "I invite you to explore the website and sense whether my approach feels right for you. My work is holistic and engaged, and questions about my practice or therapeutic framework are welcome.",
          },
          {
            name: "How often should sessions take place?",
            text: "We discuss this during the first session. The rhythm depends on your capacity, integration time, wishes and needs.",
          },
          {
            name: "Why do sessions last 1 hour 30 minutes?",
            text: "This format offers enough space to feel, settle and share without rushing the therapeutic process.",
          },
          {
            name: "What kind of space do I offer?",
            text: "I offer a welcoming environment with attentive and calm listening, so I can be present and available during each session.",
          },
        ];

  return {
    "@type": "FAQPage",
    "@id": `${new URL(Astro.url.pathname, SITE.url).href}#faq`,
    mainEntity: questions.map((question) => ({
      "@type": "Question",
      name: question.name,
      acceptedAnswer: {
        "@type": "Answer",
        text: question.text,
      },
    })),
  };
}

const pageUrl = new URL(Astro.url.pathname, SITE.url).href;
const breadcrumbStructuredData = buildBreadcrumbStructuredData(
  breadcrumbs,
  pageUrl
);
const pageStructuredData =
  pageSlug === "services" ? [getServiceFaqStructuredData()] : [];
const combinedStructuredData = [
  ...pageStructuredData,
  ...(breadcrumbStructuredData ? [breadcrumbStructuredData] : []),
  ...(structuredData
    ? Array.isArray(structuredData)
      ? structuredData
      : [structuredData]
    : []),
];
---

<BaseLayout
  title={seoTitle || title}
  description={seoDescription || description}
  image={image}
  lcpImage={lcpImage?.src}
  lcpImageSrcset={lcpImage?.srcset}
  lcpImageSizes="100vw"
  structuredData={combinedStructuredData}
>
  {
    pageSlug === "services" ? (
      <ServicesHero locale={locale} />
    ) : hasHero ? (
      <Hero
        title={heroTitle ?? title}
        subtitle={description ?? ""}
        backgroundImage={image!}
        backgroundPosition="bottom center"
        subtitleFirst={Boolean(description)}
      />
    ) : (
      <Section tone="soft" class="page-hero">
        <Container narrow>
          <Breadcrumb items={breadcrumbs} locale={locale} schema={false} />
          <h1>{title}</h1>
          {description && <p class="page-description">{description}</p>}
        </Container>
      </Section>
    )
  }

  <Container wide>
    <article class="prose prose-wide">
      <slot />
    </article>
  </Container>

  {
    pageSlug === "services" && journalPosts.length > 0 && (
      <RelatedPostsCarousel
        posts={journalPosts}
        locale={locale}
        heading={t.services.journalTitle}
        readMoreLabel={t.blog.readMore}
        dateLocale={t.locale.date}
        prevLabel={t.blogPost.relatedPrev}
        nextLabel={t.blogPost.relatedNext}
        carouselLabel={t.services.journalCarouselLabel}
        goToSlideLabel={t.carousel.goToSlide}
      />
    )
  }

  {
    homeReviews && (
      <ReviewsBlock
        title={homeReviews.title}
        items={homeReviews.items}
        prevLabel={t.reviews.prev}
        nextLabel={t.reviews.next}
        carouselLabel={t.reviews.carouselLabel}
        goToSlideLabel={t.carousel.goToSlide}
        starsLabel={t.reviews.starsLabel}
      />
    )
  }

  <PageIntroEnhancer />
  <PageCtaEnhancer />
  {pageSlug === "a-propos" && <AboutImageSplitEnhancer />}
  {(pageSlug === "a-propos" || pageSlug === "services") && <ProseQuoteEnhancer />}
  {pageSlug === "infos-pratiques" && <InfosPratiquesBookingEnhancer />}
  {pageSlug === "infos-pratiques" && <InfosPratiquesNotesEnhancer />}
  {pageSlug === "psychotherapie" && <PsychotherapieApproachEnhancer />}
  {pageSlug === "psychotherapie" && <PsychotherapieSpecialitesEnhancer />}
  {pageSlug === "psychotherapie" && <PsychotherapieTarifEnhancer />}
  {pageSlug === "services" && <ServicesHeroEnhancer />}
  {pageSlug === "services" && <ServicesIntroEnhancer />}
  {pageSlug === "services" && <ServicesFaqEnhancer />}
  {pageSlug === "services" && <ServicesSectionsEnhancer />}
  {pageSlug === "services" && <ServicesMediaEnhancer />}
  {pageSlug === "phototherapie" && <PhotoOffersEnhancer />}
  {pageSlug === "phototherapie" && <PhotoProcessEnhancer />}
  {pageSlug === "phototherapie" && <PhotoTestimonialsEnhancer />}
  <PhotoGalleryEnhancer />
</BaseLayout>

<style>
  .page-hero {
    padding-block: var(--space-xl);
    text-align: center;
  }

  .page-description {
    margin-top: var(--space-sm);
    font-size: var(--text-lg);
    color: var(--color-text-soft);
  }

  article {
    padding-block: var(--space-lg) var(--space-xl);
  }
</style>
