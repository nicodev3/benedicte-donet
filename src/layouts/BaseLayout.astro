---
import "@/styles/fonts.css";
import "@/styles/global.css";
import Seo from "@/components/seo/Seo.astro";
import Header from "@/components/common/Header.astro";
import Footer from "@/components/common/Footer.astro";
import LazyBackgrounds from "@/components/common/LazyBackgrounds.astro";
import { getLocaleFromPath } from "@/lib/i18n";
import { getAlternateLinks } from "@/lib/seo";
import { useTranslations } from "@/lib/translations";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: Date;
  modifiedTime?: Date;
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  /** Image LCP à précharger (URL optimisée) */
  lcpImage?: string;
  lcpImageSrcset?: string;
  lcpImageSizes?: string;
}

const { lcpImage, lcpImageSrcset, lcpImageSizes, ...seoProps } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const alternateLinks = await getAlternateLinks(Astro.url.pathname);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://analytics.ahrefs.com" crossorigin />
    <link rel="dns-prefetch" href="https://analytics.ahrefs.com" />
    {
      alternateLinks.map((link) => (
        <link rel="alternate" hreflang={link.hreflang} href={link.href} />
      ))
    }
    {
      lcpImage && (
        <link
          rel="preload"
          as="image"
          href={lcpImage}
          imagesrcset={lcpImageSrcset}
          imagesizes={lcpImageSizes ?? "100vw"}
          fetchpriority="high"
        />
      )
    }
    <link
      rel="preload"
      href="/fonts/CaviarDreams_Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <slot name="head" />
    <Seo {...seoProps} />
    <script is:inline>
      function loadAhrefs() {
        if (window.__ahrefsLoaded) return;
        window.__ahrefsLoaded = true;
        const s = document.createElement("script");
        s.src = "https://analytics.ahrefs.com/analytics.js";
        s.dataset.key = "rgHU3hRy3rHRn0BXIeWHxw";
        s.async = true;
        document.head.appendChild(s);
      }
      const bootAhrefs = () => {
        if ("requestIdleCallback" in window) {
          requestIdleCallback(loadAhrefs, { timeout: 6000 });
        } else {
          setTimeout(loadAhrefs, 6000);
        }
      };
      ["scroll", "click", "touchstart", "keydown"].forEach((evt) => {
        addEventListener(evt, loadAhrefs, { once: true, passive: true });
      });
      addEventListener("load", bootAhrefs, { once: true });
    </script>
  </head>
  <body>
    <a href="#contenu" class="skip-link">
      {t.common.skipToContent}
    </a>
    <Header />
    <main id="contenu">
      <slot />
    </main>
    <Footer />
    <LazyBackgrounds />
  </body>
</html>
