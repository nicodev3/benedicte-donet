---
import BaseLayout from "./BaseLayout.astro";
import Container from "@/components/common/Container.astro";
import Button from "@/components/common/Button.astro";
import SiteImage from "@/components/common/SiteImage.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import { buildBreadcrumbs } from "@/lib/breadcrumbs";
import { getGlobalSettings } from "@/lib/settings";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const {
  title,
  excerpt,
  date,
  updated,
  image,
  imageAlt,
  seoTitle,
  seoDescription,
} = post.data;

const global = await getGlobalSettings();

const breadcrumbs = buildBreadcrumbs(Astro.url.pathname, title, undefined, {
  label: "Blog",
  url: "/blog/",
});

const formattedDate = new Intl.DateTimeFormat("fr-FR", {
  dateStyle: "long",
}).format(date);
---

<BaseLayout
  title={seoTitle || title}
  description={seoDescription || excerpt}
  image={image}
  type="article"
  publishedTime={date}
  modifiedTime={updated}
>
  <Container narrow>
    <article class="post">
      <header class="post-header">
        <Breadcrumb items={breadcrumbs} />
        <p class="post-meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
        </p>
        <h1>{title}</h1>
        {excerpt && <p class="post-excerpt">{excerpt}</p>}
        {
          image && (
            <SiteImage
              src={image}
              alt={imageAlt || title}
              class="post-image"
              width={1400}
              widths={[600, 900, 1400]}
              sizes="(max-width: 800px) 100vw, 736px"
              loading="eager"
              fetchpriority="high"
            />
          )
        }
      </header>

      <div class="prose">
        <slot />
      </div>

      <footer class="post-footer">
        <p>
          Envie d'aller plus loin ? Je vous accompagne en téléconsultation.
        </p>
        <Button href={global.appointmentUrl}>Je prends rendez-vous</Button>
      </footer>
    </article>
  </Container>
</BaseLayout>

<style>
  .post {
    padding-block: var(--space-xl);
  }

  .post-header {
    margin-bottom: var(--space-lg);
  }

  .post-meta {
    font-size: var(--text-sm);
    color: var(--color-text-soft);
    margin-bottom: var(--space-md);
  }

  .post-excerpt {
    margin-top: var(--space-sm);
    font-size: var(--text-lg);
    color: var(--color-text-soft);
  }

  .post-image {
    margin-top: var(--space-md);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
  }

  .post-footer {
    margin-top: var(--space-xl);
    padding: var(--space-lg);
    background: var(--color-bg-soft);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .post-footer p {
    margin-bottom: var(--space-sm);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-lg);
  }
</style>
