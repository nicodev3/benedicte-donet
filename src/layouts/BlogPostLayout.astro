---
import { getCollection } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import Container from "@/components/common/Container.astro";
import Button from "@/components/common/Button.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import ShareButtons from "@/components/common/ShareButtons.astro";
import PostHero from "@/components/sections/PostHero.astro";
import RelatedPostsCarousel from "@/components/sections/RelatedPostsCarousel.astro";
import { buildBreadcrumbs } from "@/lib/breadcrumbs";
import { getRelatedPosts } from "@/lib/blog";
import { getGlobalSettings } from "@/lib/settings";
import { getLocaleFromPath, localizedPath } from "@/lib/i18n";
import { useTranslations } from "@/lib/translations";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const {
  title,
  excerpt,
  date,
  updated,
  image,
  seoTitle,
  seoDescription,
} = post.data;

const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const global = await getGlobalSettings(locale);

const breadcrumbs = buildBreadcrumbs(Astro.url.pathname, title, undefined, {
  label: "Blog",
  url: localizedPath("/blog/", locale),
}, locale);

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const relatedPosts = getRelatedPosts(allPosts, post.id, locale);

---

<BaseLayout
  title={seoTitle || title}
  description={seoDescription || excerpt}
  image={image}
  type="article"
  publishedTime={date}
  modifiedTime={updated}
>
  <PostHero
    title={title}
    date={date}
    dateLocale={t.locale.date}
    backgroundImage={image}
  />

  <Container narrow>
    <article class="post">
      <div class="post-breadcrumb">
        <Breadcrumb items={breadcrumbs} />
      </div>

      <ShareButtons
        title={title}
        labels={{
          title: t.blogPost.shareTitle,
          facebook: t.blogPost.shareFacebook,
          linkedin: t.blogPost.shareLinkedIn,
          whatsapp: t.blogPost.shareWhatsApp,
          email: t.blogPost.shareEmail,
          copyLink: t.blogPost.shareCopyLink,
          linkCopied: t.blogPost.shareLinkCopied,
        }}
      />

      {excerpt && <p class="post-excerpt">{excerpt}</p>}

      <div class="prose">
        <slot />
      </div>

      <footer class="post-footer">
        <p>
          {t.blogPost.footerText}
        </p>
        <Button href={global.appointmentUrl}>{t.blogPost.footerCta}</Button>
      </footer>
    </article>
  </Container>

  <RelatedPostsCarousel
    posts={relatedPosts}
    locale={locale}
    heading={t.blogPost.relatedTitle}
    readMoreLabel={t.blog.readMore}
    dateLocale={t.locale.date}
    prevLabel={t.blogPost.relatedPrev}
    nextLabel={t.blogPost.relatedNext}
    carouselLabel={t.blogPost.relatedCarouselLabel}
    goToSlideLabel={t.carousel.goToSlide}
  />
</BaseLayout>

<style>
  .post-breadcrumb {
    margin-bottom: var(--space-md);
  }

  .post-breadcrumb :global(.breadcrumb) {
    margin-bottom: 0;
  }

  .post {
    padding-block: var(--space-xl);
  }

  .post-excerpt {
    margin: 0 0 var(--space-lg);
    font-size: var(--text-lg);
    color: var(--color-text-soft);
  }

  .post-footer {
    margin-top: var(--space-xl);
    padding: var(--space-lg);
    background: var(--color-bg-soft);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .post-footer p {
    margin-bottom: var(--space-sm);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-lg);
  }
</style>
