---
import { getCollection } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import Container from "@/components/common/Container.astro";
import Button from "@/components/common/Button.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import ShareButtons from "@/components/common/ShareButtons.astro";
import PostHero from "@/components/sections/PostHero.astro";
import RelatedPostsCarousel from "@/components/sections/RelatedPostsCarousel.astro";
import { buildBreadcrumbs } from "@/lib/breadcrumbs";
import { getRelatedPosts } from "@/lib/blog";
import { getSiteGlobal } from "@/site.config";
import { getLocaleFromPath, localizedPath } from "@/lib/i18n";
import { slugifyTag } from "@/lib/tags";
import { useTranslations } from "@/lib/translations";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const {
  title,
  excerpt,
  tags,
  date,
  updated,
  image,
  seoTitle,
  seoDescription,
} = post.data;

const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const global = getSiteGlobal(locale);

const breadcrumbs = buildBreadcrumbs(Astro.url.pathname, title, undefined, {
  label: "Blog",
  url: localizedPath("/blog/", locale),
}, locale);

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const relatedPosts = getRelatedPosts(allPosts, post.id, locale);
const serviceLinks = [
  {
    href: localizedPath("/psychotherapie/", locale),
    title: t.blogPost.serviceLinks.psychotherapyTitle,
    text: t.blogPost.serviceLinks.psychotherapyText,
  },
  {
    href: localizedPath("/therapie-emdr/", locale),
    title: t.blogPost.serviceLinks.emdrTitle,
    text: t.blogPost.serviceLinks.emdrText,
  },
  {
    href: localizedPath("/infos-pratiques/", locale),
    title: t.blogPost.serviceLinks.practicalInfoTitle,
    text: t.blogPost.serviceLinks.practicalInfoText,
  },
];

---

<BaseLayout
  title={seoTitle || title}
  description={seoDescription || excerpt}
  image={image}
  type="article"
  publishedTime={date}
  modifiedTime={updated}
>
  <PostHero
    title={title}
    date={date}
    dateLocale={t.locale.date}
    backgroundImage={image}
  />

  <Container narrow>
    <article class="post">
      <div class="post-breadcrumb">
        <Breadcrumb items={breadcrumbs} />
      </div>

      <ShareButtons
        title={title}
        labels={{
          title: t.blogPost.shareTitle,
          facebook: t.blogPost.shareFacebook,
          linkedin: t.blogPost.shareLinkedIn,
          whatsapp: t.blogPost.shareWhatsApp,
          email: t.blogPost.shareEmail,
          copyLink: t.blogPost.shareCopyLink,
          linkCopied: t.blogPost.shareLinkCopied,
        }}
      />

      {tags.length > 0 && (
        <ul class="post-tags" aria-label={t.blogPost.tagsLabel}>
          {tags.map((tag) => (
            <li>
              <a href={localizedPath(`/blog/tag/${slugifyTag(tag)}/`, locale)}>{tag}</a>
            </li>
          ))}
        </ul>
      )}

      {excerpt && <p class="post-excerpt">{excerpt}</p>}

      <div class="prose">
        <slot />
      </div>

      <nav class="post-service-links" aria-labelledby="post-service-links-title">
        <h2 id="post-service-links-title">{t.blogPost.serviceLinksTitle}</h2>
        <ul>
          {
            serviceLinks.map((link) => (
              <li>
                <a href={link.href}>
                  <strong>{link.title}</strong>
                  <span>{link.text}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <footer class="post-footer">
        <p>
          {t.blogPost.footerText}
        </p>
        <Button href={global.appointmentUrl}>{t.blogPost.footerCta}</Button>
      </footer>
    </article>
  </Container>

  <RelatedPostsCarousel
    posts={relatedPosts}
    locale={locale}
    heading={t.blogPost.relatedTitle}
    readMoreLabel={t.blog.readMore}
    dateLocale={t.locale.date}
    prevLabel={t.blogPost.relatedPrev}
    nextLabel={t.blogPost.relatedNext}
    carouselLabel={t.blogPost.relatedCarouselLabel}
    goToSlideLabel={t.carousel.goToSlide}
  />
</BaseLayout>

<style>
  .post-breadcrumb {
    margin-bottom: var(--space-md);
  }

  .post-breadcrumb :global(.breadcrumb) {
    margin-bottom: 0;
  }

  .post {
    padding-block: var(--space-xl);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 var(--space-md);
    padding: 0;
    list-style: none;
  }

  .post-tags a {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--color-primary);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: var(--color-primary-dark);
    text-decoration: none;
    transition:
      background-color var(--transition),
      color var(--transition);
  }

  .post-tags a:hover {
    background-color: var(--color-primary);
    color: #fff;
  }

  .post-excerpt {
    margin: 0 0 var(--space-lg);
    font-size: var(--text-lg);
    color: var(--color-text-soft);
  }

  .post-service-links {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid rgba(126, 96, 96, 0.18);
  }

  .post-service-links h2 {
    margin: 0 0 var(--space-md);
    font-size: var(--text-xl);
    text-align: center;
  }

  .post-service-links ul {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-sm);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .post-service-links a {
    display: grid;
    gap: 0.45rem;
    height: 100%;
    padding: var(--space-md);
    border: 1px solid rgba(126, 96, 96, 0.18);
    border-radius: var(--radius-sm);
    background: #fff;
    color: inherit;
    text-decoration: none;
    transition:
      border-color var(--transition),
      transform var(--transition);
  }

  .post-service-links a:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .post-service-links strong {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    color: var(--color-primary-dark);
  }

  .post-service-links span {
    color: var(--color-text-soft);
  }

  .post-footer {
    margin-top: var(--space-xl);
    padding: var(--space-lg);
    background: var(--color-bg-soft);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .post-footer p {
    margin-bottom: var(--space-sm);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-lg);
  }

  @media (max-width: 800px) {
    .post-service-links ul {
      grid-template-columns: 1fr;
    }
  }
</style>
