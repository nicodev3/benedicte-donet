---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/common/Container.astro";
import Hero from "@/components/sections/Hero.astro";
import PostGrid from "@/components/blog/PostGrid.astro";
import { getLocaleFromFilePath, type Locale } from "@/lib/i18n";
import { useTranslations } from "@/lib/translations";

interface Props {
  locale?: Locale;
}

const { locale = "fr" } = Astro.props;
const t = useTranslations(locale);
const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .filter((post) => getLocaleFromFilePath(post.filePath) === locale)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const blogHeroImage = "/images/heroes/hero-blog.png";
---

<BaseLayout title="Blog" description={t.blog.description} image={blogHeroImage}>
  <Hero
    title={t.blog.heroTitle}
    subtitle={t.blog.heroSubtitle}
    backgroundImage={blogHeroImage}
    subtitleFirst
  />

  <Container>
    <PostGrid posts={posts} locale={locale} />
  </Container>
</BaseLayout>
