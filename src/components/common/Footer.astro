---
import Container from "./Container.astro";
import Button from "./Button.astro";
import SiteImage from "./SiteImage.astro";
import { getGlobalSettings, getFooterSettings } from "@/lib/settings";
import { getLocaleFromPath, localizedPath } from "@/lib/i18n";
import { useTranslations } from "@/lib/translations";

const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const global = await getGlobalSettings(locale);
const footer = await getFooterSettings(locale);

const year = new Date().getFullYear();
---

<footer class="footer">
  <Container>
    <div class="footer-grid">
      <div class="footer-about">
        <SiteImage
          src="/images/wp/logo-benedicte-donet.png"
          alt={`Logo ${global.siteName}`}
          width={150}
          height={60}
          loading="lazy"
        />
        <p>{footer.text}</p>
        <Button href={footer.cta.url}>{footer.cta.label}</Button>
      </div>

      <nav class="footer-links" aria-label={t.footer.quickLinks}>
        <h3>{t.common.navigation}</h3>
        <ul>
          {
            footer.quickLinks.map((link) => (
              <li>
                <a href={localizedPath(link.url, locale)}>{link.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="footer-contact">
        <h3>{t.common.contact}</h3>
        <ul>
          <li>
            <a href={`tel:${global.phone.replace(/\s/g, "")}`}>{global.phone}</a>
          </li>
          <li>
            <a href={`mailto:${global.email}`}>{global.email}</a>
          </li>
          {global.area && <li>{global.area}</li>}
        </ul>
        <div class="socials">
          {
            global.instagramUrl && (
              <a
                href={global.instagramUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                Instagram
              </a>
            )
          }
          {
            global.facebookUrl && (
              <a
                href={global.facebookUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                Facebook
              </a>
            )
          }
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {year} {global.siteName}. {t.footer.allRightsReserved}</p>
      <ul>
        {
          footer.legalLinks.map((link) => (
            <li>
              <a href={localizedPath(link.url, locale)}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </Container>
</footer>

<style>
  .footer {
    background: var(--color-bg-soft);
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-xl) var(--space-md);
    margin-top: var(--space-2xl);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-lg);
  }

  .footer-about :global(img) {
    height: 56px;
    width: auto;
    margin-bottom: var(--space-sm);
  }

  .footer-about p {
    margin-bottom: var(--space-sm);
    color: var(--color-text-soft);
    max-width: 34rem;
  }

  .footer h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-xs);
  }

  .footer ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer li + li {
    margin-top: 0.4rem;
  }

  .footer a {
    color: var(--color-text-soft);
    text-decoration: none;
  }

  .footer a:hover {
    color: var(--color-primary-dark);
    text-decoration: underline;
  }

  .socials {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  .socials a {
    font-weight: 500;
    color: var(--color-primary-dark);
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-sm);
    color: var(--color-text-soft);
  }

  .footer-bottom ul {
    display: flex;
    gap: var(--space-md);
  }

  .footer-bottom li + li {
    margin-top: 0;
  }

  @media (max-width: 760px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
