---
import Container from "./Container.astro";
import Button from "./Button.astro";
import SiteImage from "./SiteImage.astro";
import { ChevronDown, Menu, X } from "@lucide/astro";
import { getSiteGlobal } from "@/site.config";
import { getNavigationItems } from "@/lib/navigation";
import {
  alternateLocalePath,
  getAlternateLocale,
  getLocaleFromPath,
  getLocaleSwitchLabel,
  localizedPath,
} from "@/lib/i18n";
import { getAlternateTagSlug } from "@/lib/tags";
import { useTranslations } from "@/lib/translations";
import { getCollection } from "astro:content";

const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const global = getSiteGlobal(locale);
const items = getNavigationItems(locale);

const currentPath = Astro.url.pathname;
const languageLabel = getLocaleSwitchLabel(locale);
const alternateLocale = getAlternateLocale(locale);
// Tag slugs are translated independently (for example, "respiration" and
// "breathing"). Switch to the paired tag when possible, else fall back to /blog/.
const tagMatch = currentPath.match(/^\/(?:en\/)?blog\/tag\/([^/]+)\/$/);
let languageUrl = alternateLocalePath(currentPath, locale);
if (tagMatch?.[1]) {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const alternateTag = getAlternateTagSlug(posts, locale, tagMatch[1]);
  languageUrl = alternateTag
    ? localizedPath(`/blog/tag/${alternateTag}/`, alternateLocale)
    : localizedPath("/blog/", alternateLocale);
}
const languageFlagSrc =
  alternateLocale === "fr" ? "/images/ui/flag-fr.svg" : "/images/ui/flag-en.svg";

function isActive(url: string): boolean {
  const localizedUrl = localizedPath(url, locale);
  if (localizedUrl === "/") return currentPath === "/";
  return currentPath.startsWith(localizedUrl);
}

function isItemActive(item: (typeof items)[number]): boolean {
  return item.children?.some((child) => isActive(child.url)) ?? false;
}

function visibleChildren(item: (typeof items)[number]) {
  return item.children ?? [];
}
---

<header class="header">
  <Container>
    <div class="header-inner">
      <a href={localizedPath("/", locale)} class="brand" aria-label={global.siteName}>
        <SiteImage
          src="/images/ui/logo-benedicte-donet-text.png"
          alt={`Logo ${global.siteName}`}
          width={150}
          widths={[56, 112, 150]}
          loading="eager"
          fetchpriority="low"
        />
      </a>

      <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
      <label for="nav-toggle" class="nav-toggle-label" aria-label={t.header.openMenu}>
        <Menu class="nav-icon nav-icon-open" size={24} aria-hidden="true" />
        <X class="nav-icon nav-icon-close" size={24} aria-hidden="true" />
      </label>

      <nav class="nav" aria-label={t.header.mainNavigation}>
        <ul>
          {
            items.map((item) => {
              const children = visibleChildren(item);
              const hasDropdown = children.length > 0;
              const dropdownId = `nav-dropdown-${item.label.toLowerCase().replace(/\s+/g, "-")}`;

              return (
                <li class:list={[{ "has-dropdown": hasDropdown }]}>
                  {hasDropdown ? (
                    <>
                      <button
                        type="button"
                        class="nav-link nav-trigger"
                        aria-current={isItemActive(item) ? "page" : undefined}
                        aria-haspopup="true"
                        aria-expanded="false"
                        aria-controls={dropdownId}
                      >
                        {item.label}
                        <ChevronDown size={16} aria-hidden="true" class="nav-chevron" />
                      </button>
                      <ul class="dropdown" id={dropdownId}>
                        {children.map((child) => (
                          <li>
                            <a
                              href={localizedPath(child.url, locale)}
                              aria-current={
                                isActive(child.url) ? "page" : undefined
                              }
                            >
                              {child.label}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </>
                  ) : (
                    <a
                      href={localizedPath(item.url, locale)}
                      aria-current={isActive(item.url) ? "page" : undefined}
                    >
                      {item.label}
                    </a>
                  )}
                </li>
              );
            })
          }
        </ul>
        <Button href={global.appointmentUrl} class="nav-cta">
          {t.header.appointmentCta}
        </Button>
        <a href={languageUrl} class="language-switch" hreflang={alternateLocale}>
          <SiteImage
            class="language-flag"
            src={languageFlagSrc}
            alt={alternateLocale === "fr" ? "Français" : "English"}
            width={20}
            height={14}
          />
          <span>{languageLabel}</span>
        </a>
      </nav>
    </div>
  </Container>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding-block: 1rem;
  }

  @media (min-width: 901px) {
    .header-inner {
      height: 170px;
      padding-block: 0;
    }

    .nav a,
    .nav-trigger {
      font-size: 20px;
    }
  }

  .brand :global(img) {
    height: 100%;
    width: auto;
    object-fit: contain;
  }

  .nav > ul {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav > ul > li {
    position: relative;
  }

  .nav a,
  .nav-trigger {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-trigger {
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }

  .nav a:hover,
  .nav a[aria-current="page"],
  .nav-trigger:hover,
  .nav-trigger:focus-visible,
  .nav-trigger[aria-current="page"] {
    color: var(--color-primary-dark);
  }

  .has-dropdown > .nav-trigger::after {
    content: none;
  }

  .nav-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-chevron {
    flex-shrink: 0;
  }

  .dropdown {
    display: none;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    min-width: 12rem;
    margin: 0;
    padding: 0.4rem 0;
    list-style: none;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    box-shadow: var(--shadow-soft);
    z-index: 60;
  }

  .dropdown::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 100%;
    height: 0.5rem;
  }

  .dropdown a {
    display: block;
    padding: 0.55rem 1rem;
    white-space: nowrap;
  }

  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    display: flex;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    min-width: 0;
  }

  .nav :global(.nav-cta) {
    flex-shrink: 0;
    white-space: nowrap;
    font-size: var(--text-sm);
    padding: 0.6em 1.4em;
  }

  .language-switch {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.35rem 0.6rem;
    line-height: 1;
  }

  .language-flag {
    display: inline-block;
    width: 20px;
    height: 14px;
    border-radius: 2px;
    overflow: hidden;
    flex-shrink: 0;
  }

  /* Menu mobile en CSS pur (pas de JavaScript) */
  .nav-toggle {
    display: none;
  }

  .nav-toggle-label {
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 8px;
    color: var(--color-text);
  }

  .nav-icon-close {
    display: none;
  }

  .nav-toggle:checked ~ .nav-toggle-label .nav-icon-open {
    display: none;
  }

  .nav-toggle:checked ~ .nav-toggle-label .nav-icon-close {
    display: block;
  }

  @media (max-width: 900px) {
    .brand :global(img) {
      height: 48px;
      width: auto;
    }

    .nav-toggle-label {
      display: flex;
    }

    .nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: #fff;
      border-bottom: 1px solid var(--color-border);
      padding: var(--space-md);
      box-shadow: var(--shadow-soft);
    }

    .nav > ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .nav a {
      display: block;
      padding: 0.7rem 0;
      font-size: var(--text-base);
    }

    .has-dropdown > .nav-trigger::after {
      display: none;
    }

    .nav-chevron {
      display: none;
    }

    .nav-trigger {
      display: block;
      padding: 0.7rem 0;
      font-size: var(--text-base);
    }

    .dropdown {
      display: block;
      position: static;
      transform: none;
      min-width: 0;
      margin: 0;
      padding: 0 0 0 1rem;
      background: transparent;
      border: none;
      border-radius: 0;
      box-shadow: none;
    }

    .dropdown::before {
      display: none;
    }

    .dropdown a {
      padding: 0.5rem 0;
      font-size: var(--text-sm);
      font-weight: 600;
    }

    .nav-toggle:checked ~ .nav {
      display: flex;
    }
  }

  @media (min-width: 901px) {
    .brand {
      display: flex;
      align-items: center;
      height: 100%;
    }

    .nav a,
    .nav-trigger {
      font-size: 20px;
    }

    .brand :global(img) {
      height: auto;
      max-height: 100%;
      width: auto;
    }
  }

  /* Desktop étroit : éviter que le CTA « Prendre RDV » se comprime */
  @media (min-width: 901px) and (max-width: 1180px) {
    .header-inner {
      gap: var(--space-sm);
    }

    .nav {
      gap: var(--space-sm);
    }

    .nav > ul {
      gap: 0.75rem;
    }

    .nav a,
    .nav-trigger {
      font-size: var(--text-base);
    }

    .nav :global(.nav-cta) {
      padding: 0.55em 1.35em;
    }
  }
</style>
