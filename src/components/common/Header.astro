---
import Container from "./Container.astro";
import Button from "./Button.astro";
import SiteImage from "./SiteImage.astro";
import {
  getGlobalSettings,
  getNavigationSettings,
} from "@/lib/settings";
import {
  alternateLocalePath,
  getAlternateLocale,
  getLocaleFromPath,
  getLocaleSwitchLabel,
  localizedPath,
} from "@/lib/i18n";
import { useTranslations } from "@/lib/translations";

const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const global = await getGlobalSettings(locale);
const navigation = await getNavigationSettings(locale);

const items = navigation.items
  .filter((item) => item.visible)
  .sort((a, b) => a.order - b.order);

const currentPath = Astro.url.pathname;
const languageLabel = getLocaleSwitchLabel(locale);
const alternateLocale = getAlternateLocale(locale);
const languageUrl = alternateLocalePath(currentPath, locale);

function isActive(url: string): boolean {
  const localizedUrl = localizedPath(url, locale);
  if (localizedUrl === "/") return currentPath === "/";
  return currentPath.startsWith(localizedUrl);
}

function isItemActive(item: (typeof items)[number]): boolean {
  return (
    item.children?.some((child) => child.visible && isActive(child.url)) ?? false
  );
}

function visibleChildren(item: (typeof items)[number]) {
  return item.children?.filter((child) => child.visible) ?? [];
}
---

<header class="header">
  <Container>
    <div class="header-inner">
      <a href={localizedPath("/", locale)} class="brand" aria-label={global.siteName}>
        <SiteImage
          src="/images/wp/logo-benedicte-donet.png"
          alt={`Logo ${global.siteName}`}
          width={150}
          height={60}
          loading="eager"
        />
      </a>

      <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
      <label for="nav-toggle" class="nav-toggle-label" aria-label={t.header.openMenu}>
        <span></span>
        <span></span>
        <span></span>
      </label>

      <nav class="nav" aria-label={t.header.mainNavigation}>
        <ul>
          {
            items.map((item) => {
              const children = visibleChildren(item);
              const hasDropdown = children.length > 0;
              const dropdownId = `nav-dropdown-${item.label.toLowerCase().replace(/\s+/g, "-")}`;

              return (
                <li class:list={[{ "has-dropdown": hasDropdown }]}>
                  {hasDropdown ? (
                    <>
                      <button
                        type="button"
                        class="nav-link nav-trigger"
                        aria-current={isItemActive(item) ? "page" : undefined}
                        aria-haspopup="true"
                        aria-expanded="false"
                        aria-controls={dropdownId}
                      >
                        {item.label}
                      </button>
                      <ul class="dropdown" id={dropdownId}>
                        {children.map((child) => (
                          <li>
                            <a
                              href={localizedPath(child.url, locale)}
                              aria-current={
                                isActive(child.url) ? "page" : undefined
                              }
                            >
                              {child.label}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </>
                  ) : (
                    <a
                      href={localizedPath(item.url, locale)}
                      aria-current={isActive(item.url) ? "page" : undefined}
                    >
                      {item.label}
                    </a>
                  )}
                </li>
              );
            })
          }
        </ul>
        <Button href={global.appointmentUrl} class="nav-cta">
          {t.header.appointmentCta}
        </Button>
        <a href={languageUrl} class="language-switch" hreflang={alternateLocale}>
          {languageLabel}
        </a>
      </nav>
    </div>
  </Container>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding-block: 0.6rem;
  }

  .brand :global(img) {
    height: 56px;
    width: auto;
  }

  .nav > ul {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav > ul > li {
    position: relative;
  }

  .nav a,
  .nav-trigger {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-trigger {
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }

  .nav a:hover,
  .nav a[aria-current="page"],
  .nav-trigger:hover,
  .nav-trigger:focus-visible,
  .nav-trigger[aria-current="page"] {
    color: var(--color-primary-dark);
  }

  .has-dropdown > .nav-trigger::after {
    content: "";
    display: inline-block;
    width: 0.45em;
    height: 0.45em;
    margin-left: 0.35em;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: translateY(-0.15em) rotate(45deg);
    vertical-align: middle;
  }

  .dropdown {
    display: none;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    min-width: 12rem;
    margin: 0;
    padding: 0.4rem 0;
    list-style: none;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    box-shadow: var(--shadow-soft);
    z-index: 60;
  }

  .dropdown::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 100%;
    height: 0.5rem;
  }

  .dropdown a {
    display: block;
    padding: 0.55rem 1rem;
    white-space: nowrap;
  }

  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    display: flex;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .nav :global(.nav-cta) {
    font-size: var(--text-sm);
    padding: 0.6em 1.4em;
  }

  .language-switch {
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.35rem 0.6rem;
    line-height: 1;
  }

  /* Menu mobile en CSS pur (pas de JavaScript) */
  .nav-toggle {
    display: none;
  }

  .nav-toggle-label {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 8px;
  }

  .nav-toggle-label span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text);
    transition: transform var(--transition), opacity var(--transition);
  }

  @media (max-width: 900px) {
    .nav-toggle-label {
      display: flex;
    }

    .nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: #fff;
      border-bottom: 1px solid var(--color-border);
      padding: var(--space-md);
      box-shadow: var(--shadow-soft);
    }

    .nav > ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .nav a {
      display: block;
      padding: 0.7rem 0;
      font-size: var(--text-base);
    }

    .has-dropdown > .nav-trigger::after {
      display: none;
    }

    .nav-trigger {
      display: block;
      padding: 0.7rem 0;
      font-size: var(--text-base);
    }

    .dropdown {
      display: block;
      position: static;
      transform: none;
      min-width: 0;
      margin: 0;
      padding: 0 0 0 1rem;
      background: transparent;
      border: none;
      border-radius: 0;
      box-shadow: none;
    }

    .dropdown::before {
      display: none;
    }

    .dropdown a {
      padding: 0.5rem 0;
      font-size: var(--text-sm);
      font-weight: 600;
    }

    .nav-toggle:checked ~ .nav {
      display: flex;
    }

    .nav-toggle:checked ~ .nav-toggle-label span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .nav-toggle:checked ~ .nav-toggle-label span:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle:checked ~ .nav-toggle-label span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>
