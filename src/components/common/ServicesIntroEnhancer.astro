---
/**
 * Section intro Services : image téléconsultation à gauche, texte à droite (comme la prod).
 */
---

<script>
  function extractImageParagraph(paragraph: Element): HTMLImageElement | null {
    if (paragraph.tagName !== "P") return null;

    const imgs = [...paragraph.querySelectorAll("img")];
    if (imgs.length !== 1) return null;

    const clone = paragraph.cloneNode(true) as HTMLElement;
    clone.querySelectorAll("img").forEach((img) => img.remove());
    const leftover = clone.textContent?.replace(/\[/g, "").trim() ?? "";
    if (leftover) return null;

    return imgs[0];
  }

  function buildServicesIntro(prose: HTMLElement) {
    if (prose.dataset.servicesSplitReady === "true") return;

    const imageParagraph = prose.firstElementChild;
    if (!imageParagraph) return;

    const sourceImg = extractImageParagraph(imageParagraph);
    if (!sourceImg) return;

    const textNodes: Element[] = [];
    let foundFirstH2 = false;
    let next = imageParagraph.nextElementSibling;

    while (next) {
      if (next.tagName === "H2") {
        if (foundFirstH2) break;
        foundFirstH2 = true;
      }

      textNodes.push(next);
      next = next.nextElementSibling;
    }

    if (!textNodes.length) return;

    const intro = document.createElement("section");
    intro.className = "page-intro services-intro";

    const imageCol = document.createElement("div");
    imageCol.className = "page-intro-image";

    const imageInner = document.createElement("div");
    imageInner.className = "page-intro-image-inner";

    const image = sourceImg.cloneNode(true) as HTMLImageElement;
    image.removeAttribute("width");
    image.removeAttribute("height");
    image.loading = "lazy";
    imageInner.append(image);
    imageCol.append(imageInner);

    const textCol = document.createElement("div");
    textCol.className = "page-intro-content prose";
    textNodes.forEach((node) => textCol.append(node));

    const heading = textCol.querySelector("h2");
    if (heading?.id) {
      intro.setAttribute("aria-labelledby", heading.id);
    }

    intro.append(imageCol, textCol);
    imageParagraph.remove();
    prose.insertBefore(intro, next);
    prose.dataset.servicesSplitReady = "true";
  }

  function setupServicesIntro() {
    const prose = document.querySelector<HTMLElement>(".prose");
    if (!prose) return;

    buildServicesIntro(prose);
  }

  setupServicesIntro();
  document.addEventListener("astro:page-load", setupServicesIntro);
</script>

<style is:global>
  .services-intro {
    align-items: center;
    margin-top: var(--space-lg);
  }

  .services-intro .page-intro-image-inner {
    border-radius: 0 0 0 5rem;
  }

  .services-intro .page-intro-image-inner img {
    width: 90%;
    min-height: auto;
    object-fit: contain;
    object-position: left center;
  }

  .services-intro .page-intro-content h2 {
    margin: 0 0 clamp(1.25rem, 2.5vw, 1.75rem);
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-align: center;
    color: var(--color-text);
  }

  @media (max-width: 820px) {
    .services-intro .page-intro-image-inner img {
      width: 100%;
      max-height: 20rem;
      object-fit: cover;
    }
  }
</style>
