---
/**
 * Transforme l'intro des pages service (image + texte) en grille image à gauche.
 */
---

<script>
  function extractImageParagraph(paragraph: Element): HTMLImageElement[] | null {
    if (paragraph.tagName !== "P") return null;

    const imgs = [...paragraph.querySelectorAll("img")];
    if (!imgs.length) return null;

    const clone = paragraph.cloneNode(true) as HTMLElement;
    clone.querySelectorAll("img").forEach((img) => img.remove());
    const leftover = clone.textContent?.replace(/\[/g, "").trim() ?? "";
    if (leftover) return null;

    return imgs;
  }

  function isGalleryStart(element: Element): boolean {
    const imgs = extractImageParagraph(element);
    return Boolean(imgs && imgs.length >= 3);
  }

  function buildPageIntro(prose: HTMLElement) {
    const first = prose.firstElementChild;
    if (!first) return;

    const introImgs = extractImageParagraph(first);
    if (!introImgs || introImgs.length !== 1) return;

    const textNodes: Element[] = [];
    let foundFirstH2 = false;
    let child = first.nextElementSibling;

    while (child) {
      if (isGalleryStart(child)) break;

      if (child.tagName === "H2") {
        if (foundFirstH2) break;
        foundFirstH2 = true;
      }

      const next = child.nextElementSibling;
      textNodes.push(child);
      child = next;
    }

    if (!textNodes.length) return;

    const intro = document.createElement("div");
    intro.className = "page-intro";

    const imageCol = document.createElement("div");
    imageCol.className = "page-intro-image";

    const imageInner = document.createElement("div");
    imageInner.className = "page-intro-image-inner";

    const image = introImgs[0].cloneNode(true) as HTMLImageElement;
    image.removeAttribute("width");
    image.removeAttribute("height");
    image.loading = "eager";
    imageInner.append(image);
    imageCol.append(imageInner);

    const textCol = document.createElement("div");
    textCol.className = "page-intro-content prose";
    textNodes.forEach((node) => textCol.append(node));

    intro.append(imageCol, textCol);
    first.replaceWith(intro);
  }

  function setupPageIntro() {
    document.querySelectorAll<HTMLElement>(".prose").forEach((prose) => {
      if (prose.dataset.pageIntroReady === "true") return;

      buildPageIntro(prose);
      prose.dataset.pageIntroReady = "true";
    });
  }

  setupPageIntro();
  document.addEventListener("astro:page-load", setupPageIntro);
</script>

<style is:global>
  .page-intro {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    align-items: start;
    gap: clamp(1.5rem, 4vw, 3rem);
    margin-bottom: var(--space-md);
  }

  .page-intro-image {
    position: sticky;
    top: calc(var(--space-md) + 4rem);
  }

  .page-intro-image-inner {
    overflow: hidden;
    border-radius: 1.25rem 0 0 6.25rem;
  }

  .page-intro-image-inner img {
    display: block;
    width: 100%;
    min-height: 18rem;
    object-fit: cover;
    object-position: center;
    margin: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .page-intro-content {
    max-width: none;
    margin: 0;
  }

  .page-intro-content > * + * {
    margin-top: var(--space-sm);
  }

  .page-intro-content h2 {
    margin-top: 0;
    font-family: var(--font-heading);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-primary-dark);
  }

  .page-intro-content p,
  .page-intro-content li {
    color: var(--color-text);
    font-weight: 300;
    line-height: 1.7;
  }

  .page-intro-content ul {
    margin: 0;
    padding-left: 1.2rem;
  }

  @media (max-width: 820px) {
    .page-intro {
      grid-template-columns: 1fr;
    }

    .page-intro-image {
      position: static;
    }

    .page-intro-image-inner {
      max-width: 22rem;
      margin-inline: auto;
      border-radius: 1rem 0 0 3.75rem;
    }

    .page-intro-image-inner img {
      max-height: 18rem;
    }
  }
</style>
