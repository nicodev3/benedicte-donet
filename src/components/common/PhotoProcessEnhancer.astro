---
/**
 * Section « Le déroulement du photoshoot » : texte à gauche, photo à droite.
 */
---

<script>
  function extractImageParagraph(paragraph: Element): HTMLImageElement[] | null {
    if (paragraph.tagName !== "P") return null;

    const imgs = [...paragraph.querySelectorAll("img")];
    if (!imgs.length) return null;

    const clone = paragraph.cloneNode(true) as HTMLElement;
    clone.querySelectorAll("img").forEach((img) => img.remove());
    const leftover = clone.textContent?.replace(/\[/g, "").trim() ?? "";
    if (leftover) return null;

    return imgs;
  }

  function isGalleryStart(element: Element): boolean {
    const imgs = extractImageParagraph(element);
    return Boolean(imgs && imgs.length >= 3);
  }

  function buildPhotoProcess(prose: HTMLElement) {
    const heading = prose.querySelector<HTMLElement>('h2[id^="le-déroulement-du-photoshoot"], h2[id^="le-deroulement-du-photoshoot"]');
    if (!heading || heading.dataset.processReady === "true") return;

    const textNodes: Element[] = [];
    let imageParagraph: Element | null = null;
    let next = heading.nextElementSibling;

    while (next && next.tagName !== "H2") {
      if (isGalleryStart(next)) break;

      const imgs = extractImageParagraph(next);
      if (imgs?.length === 1 && !imageParagraph) {
        imageParagraph = next;
        next = next.nextElementSibling;
        continue;
      }

      textNodes.push(next);
      next = next.nextElementSibling;
    }

    if (!imageParagraph || !textNodes.length) return;

    const split = document.createElement("div");
    split.className = "page-split page-split-reverse";

    const contentCol = document.createElement("div");
    contentCol.className = "page-split-content";

    contentCol.append(heading);
    textNodes.forEach((node) => contentCol.append(node));

    const imageCol = document.createElement("div");
    imageCol.className = "page-split-image";

    const imageInner = document.createElement("div");
    imageInner.className = "page-split-image-inner";

    const sourceImg = imageParagraph.querySelector("img");
    if (!sourceImg) return;

    const image = sourceImg.cloneNode(true) as HTMLImageElement;
    image.removeAttribute("width");
    image.removeAttribute("height");
    image.loading = "lazy";
    imageInner.append(image);
    imageCol.append(imageInner);

    split.append(contentCol, imageCol);
    imageParagraph.remove();
    prose.insertBefore(split, next);
    heading.dataset.processReady = "true";
  }

  function setupPhotoProcess() {
    const prose = document.querySelector<HTMLElement>(".prose.prose-wide");
    if (!prose || prose.dataset.photoProcessReady === "true") return;

    buildPhotoProcess(prose);
    if (prose.querySelector(".page-split-reverse")) {
      prose.dataset.photoProcessReady = "true";
    }
  }

  setupPhotoProcess();
  document.addEventListener("astro:page-load", setupPhotoProcess);
</script>

<style is:global>
  .page-split {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    align-items: start;
    gap: clamp(1.5rem, 4vw, 3rem);
    margin-block: var(--space-lg);
  }

  .page-split-content {
    max-width: none;
    margin: 0;
  }

  .page-split-content > * + * {
    margin-top: var(--space-sm);
  }

  .page-split-content h2 {
    margin-top: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.375rem, 1.1rem + 0.9vw, 1.875rem);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-primary-dark);
  }

  .page-split-content h3 {
    font-family: var(--font-body);
    font-size: clamp(1rem, 0.9rem + 0.35vw, 1.25rem);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-secondary);
  }

  .page-split-content p,
  .page-split-content li {
    color: var(--color-text);
    font-weight: 300;
    line-height: 1.7;
  }

  .page-split-image {
    position: sticky;
    top: calc(var(--space-md) + 4rem);
  }

  .page-split-image-inner {
    overflow: hidden;
    border-radius: 1.25rem 0 0 6.25rem;
  }

  .page-split-image-inner img {
    display: block;
    width: 100%;
    min-height: 18rem;
    object-fit: cover;
    object-position: center;
    margin: 0;
    border-radius: 0;
    box-shadow: none;
  }

  @media (max-width: 820px) {
    .page-split,
    .page-split-reverse {
      grid-template-columns: 1fr;
    }

    .page-split-image {
      position: static;
      order: -1;
    }

    .page-split-image-inner {
      max-width: 22rem;
      margin-inline: auto;
      border-radius: 1rem 0 0 3.75rem;
    }

    .page-split-image-inner img {
      max-height: 18rem;
    }
  }
</style>
