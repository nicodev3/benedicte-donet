---
interface Props {
  tone?: "default" | "soft" | "muted" | "primary";
  id?: string;
  class?: string;
  style?: Record<string, string | undefined>;
  /** URL d'image de fond chargée seulement près du viewport */
  lazyBg?: string;
  lazyBgVar?: string;
  lazyBgDesktop?: string;
  lazyBgMobile?: string;
}

const {
  tone = "default",
  id,
  class: className = "",
  style,
  lazyBg,
  lazyBgVar,
  lazyBgDesktop,
  lazyBgMobile,
} = Astro.props;
---

<section
  {id}
  class:list={["section", `tone-${tone}`, className]}
  style={style}
  data-lazy-bg={lazyBg}
  data-lazy-bg-var={lazyBgVar}
  data-lazy-bg-desktop={lazyBgDesktop}
  data-lazy-bg-mobile={lazyBgMobile}
>
  <slot />
</section>

<style>
  .section {
    padding-block: var(--space-2xl);
    /* Diffère le layout des sections hors viewport → moins de travail au chargement */
    content-visibility: auto;
    contain-intrinsic-size: auto 32rem;
  }

  .tone-soft {
    background: var(--color-bg-soft);
  }

  .tone-muted {
    background: var(--color-bg-muted);
  }

  .tone-primary {
    background: var(--color-primary-strong);
    color: #fff;
  }

  .tone-primary :global(h2),
  .tone-primary :global(h3) {
    color: #fff;
  }

  @media (max-width: 640px) {
    .section {
      padding-block: var(--space-xl);
    }
  }
</style>
