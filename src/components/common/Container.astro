---
interface Props {
  narrow?: boolean;
  class?: string;
}

const { narrow = false, class: className = "" } = Astro.props;
---

<div class:list={["container", { narrow }, className]}>
  <slot />
</div>

<style>
  .container {
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-md);
  }

  .container.narrow {
    max-width: var(--container-narrow);
  }
</style>
