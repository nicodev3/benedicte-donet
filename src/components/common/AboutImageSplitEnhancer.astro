---
/**
 * Mises en page spécifiques de la page À propos :
 * - « Mon cheminement » : texte à gauche, portrait à droite
 * - « Mon parcours de formation » : illustration à gauche, liste à droite
 */
---

<script>
  function extractImageParagraph(paragraph: Element): HTMLImageElement[] | null {
    if (paragraph.tagName !== "P") return null;

    const imgs = [...paragraph.querySelectorAll("img")];
    if (!imgs.length) return null;

    const clone = paragraph.cloneNode(true) as HTMLElement;
    clone.querySelectorAll("img").forEach((img) => img.remove());
    const leftover = clone.textContent?.replace(/\[/g, "").trim() ?? "";
    if (leftover) return null;

    return imgs;
  }

  function isGalleryStart(element: Element): boolean {
    const imgs = extractImageParagraph(element);
    return Boolean(imgs && imgs.length >= 3);
  }

  function createImageColumn(imageParagraph: Element): HTMLElement {
    const imageCol = document.createElement("div");
    imageCol.className = "page-intro-image";

    const imageInner = document.createElement("div");
    imageInner.className = "page-intro-image-inner";

    const sourceImg = imageParagraph.querySelector("img");
    if (!sourceImg) return imageCol;

    const image = sourceImg.cloneNode(true) as HTMLImageElement;
    image.removeAttribute("width");
    image.removeAttribute("height");
    image.loading = "lazy";
    imageInner.append(image);
    imageCol.append(imageInner);
    imageParagraph.remove();

    return imageCol;
  }

  function createTextColumn(textNodes: Element[]): HTMLElement {
    const textCol = document.createElement("div");
    textCol.className = "page-intro-content prose";
    textNodes.forEach((node) => textCol.append(node));
    return textCol;
  }

  function buildMonCheminementSplit(prose: HTMLElement) {
    const heading = prose.querySelector<HTMLElement>('h2[id^="mon-cheminement"]');
    if (!heading || heading.dataset.cheminementReady === "true") return;

    const textNodes: Element[] = [];
    let imageParagraph: Element | null = null;
    let next = heading.nextElementSibling;

    while (next) {
      const imgs = extractImageParagraph(next);
      if (imgs?.length === 1) {
        imageParagraph = next;
        next = next.nextElementSibling;
        break;
      }

      textNodes.push(next);
      next = next.nextElementSibling;
    }

    if (!imageParagraph || !textNodes.length) return;

    const split = document.createElement("div");
    split.className = "page-intro page-intro-reverse";

    const contentCol = document.createElement("div");
    contentCol.className = "page-intro-content prose";
    contentCol.append(heading);
    textNodes.forEach((node) => contentCol.append(node));

    const imageCol = createImageColumn(imageParagraph);
    split.append(contentCol, imageCol);
    prose.insertBefore(split, next);
    heading.dataset.cheminementReady = "true";
  }

  function buildFormationSplit(prose: HTMLElement) {
    const splits: {
      image: Element;
      texts: Element[];
      insertBefore: Element | null;
    }[] = [];

    let child = prose.firstElementChild;
    while (child) {
      if (
        child.classList.contains("page-intro") ||
        child.classList.contains("page-intro-reverse")
      ) {
        child = child.nextElementSibling;
        continue;
      }

      const imgs = extractImageParagraph(child);
      if (imgs?.length === 1) {
        const imageParagraph = child;
        const textNodes: Element[] = [];
        let next = child.nextElementSibling;

        while (next) {
          if (isGalleryStart(next)) break;

          const nextImgs = extractImageParagraph(next);
          if (nextImgs?.length === 1) break;

          textNodes.push(next);
          next = next.nextElementSibling;
        }

        if (textNodes.length) {
          splits.push({
            image: imageParagraph,
            texts: textNodes,
            insertBefore: next,
          });
        }
      }

      child = child.nextElementSibling;
    }

    for (const { image, texts, insertBefore } of splits) {
      const split = document.createElement("div");
      split.className = "page-intro";
      split.append(createImageColumn(image), createTextColumn(texts));
      prose.insertBefore(split, insertBefore);
    }
  }

  function setupAboutImageSplits() {
    const prose = document.querySelector<HTMLElement>(".prose.prose-wide");
    if (!prose || prose.dataset.aboutSplitsReady === "true") return;

    buildMonCheminementSplit(prose);
    buildFormationSplit(prose);
    prose.dataset.aboutSplitsReady = "true";
  }

  setupAboutImageSplits();
  document.addEventListener("astro:page-load", setupAboutImageSplits);
</script>

<style is:global>
  .page-intro-reverse {
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
  }

  @media (max-width: 820px) {
    .page-intro-reverse .page-intro-image {
      order: -1;
    }
  }
</style>
