---
import { Image } from "astro:assets";
import { isExternalImage, resolveImage } from "@/lib/images";

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  widths?: number[];
  sizes?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  class?: string;
}

const {
  src,
  alt,
  width,
  height,
  widths,
  sizes,
  loading = "lazy",
  fetchpriority,
  class: className,
} = Astro.props;

const image = resolveImage(src);
const isExternal = isExternalImage(src);

if (!image && !isExternal) {
  console.warn(`[SiteImage] Image introuvable dans src/assets : ${src}`);
}
---

{
  image && (
    <Image
      src={image}
      alt={alt}
      width={width ?? (height ? undefined : image.width)}
      height={height ?? (width ? undefined : image.height)}
      widths={widths}
      sizes={sizes}
      loading={loading}
      fetchpriority={fetchpriority}
      class={className}
    />
  )
}

{
  !image && isExternal && (
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      fetchpriority={fetchpriority}
      class={className}
    />
  )
}

{
  !image && !isExternal && src.startsWith("/images/") && (
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      fetchpriority={fetchpriority}
      class={className}
    />
  )
}
