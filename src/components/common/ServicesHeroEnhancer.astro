---
/**
 * Retire les titres dupliqués du markdown Services (déjà dans ServicesHero).
 * Conserve la liste des spécialités, affichée une seule fois dans le contenu.
 */
---

<script>
  function stripServicesIntro(prose: HTMLElement) {
    if (prose.dataset.servicesIntroReady === "true") return;

    const headings = [...prose.querySelectorAll(":scope > h1, :scope > h2")].slice(
      0,
      2
    );
    if (headings.length < 2) return;

    const [eyebrow, subtitle] = headings;
    const eyebrowText = eyebrow.textContent?.trim().toLowerCase() ?? "";
    const subtitleText = subtitle.textContent?.trim().toLowerCase() ?? "";

    const isServicesEyebrow =
      eyebrowText.includes("psychologue") || eyebrowText.includes("psychologist");
    const isServicesSubtitle =
      subtitleText.includes("services") || subtitleText.includes("mes services");

    if (!isServicesEyebrow || !isServicesSubtitle) return;

    eyebrow.remove();
    subtitle.remove();
    prose.dataset.servicesIntroReady = "true";
  }

  function setupServicesIntro() {
    const prose = document.querySelector<HTMLElement>(".prose");
    if (!prose) return;

    stripServicesIntro(prose);
  }

  setupServicesIntro();
  document.addEventListener("astro:page-load", setupServicesIntro);
</script>
