---
/**
 * Section FAQ Services : accordéon stylé comme la prod Elementor.
 */
---

<script>
  const FAQ_TONES = [
    "services-faq-item--peach",
    "services-faq-item--mint",
    "services-faq-item--pink",
    "services-faq-item--taupe",
  ];

  function isQuestionParagraph(element: Element): boolean {
    if (element.tagName !== "P") return false;
    const text = element.textContent?.trim() ?? "";
    return text.endsWith("?") && !element.querySelector("a, img");
  }

  function buildFaqAccordion(prose: HTMLElement) {
    const heading = prose.querySelector<HTMLElement>(
      'h2[id^="la-foire-aux-questions"], h2[id^="frequently-asked"]'
    );
    if (!heading || prose.dataset.servicesFaqReady === "true") return;

    const items: { question: string; answerNodes: Element[] }[] = [];
    let current: { question: string; answerNodes: Element[] } | null = null;
    let next = heading.nextElementSibling;

    while (next && next.tagName !== "H2") {
      if (isQuestionParagraph(next)) {
        if (current) items.push(current);
        current = {
          question: next.textContent?.trim() ?? "",
          answerNodes: [],
        };
      } else if (current && next.tagName === "P") {
        current.answerNodes.push(next);
      }

      next = next.nextElementSibling;
    }

    if (current) items.push(current);
    if (!items.length) return;

    const section = document.createElement("section");
    section.className = "services-faq";
    section.id = "faq";

    const title = heading.cloneNode(true) as HTMLElement;
    title.className = "services-faq-title";
    title.id = heading.id;

    const list = document.createElement("div");
    list.className = "services-faq-list";

    items.forEach((item, index) => {
      const entry = document.createElement("div");
      entry.className = `services-faq-item ${FAQ_TONES[index % FAQ_TONES.length]}`;
      if (index === 0) entry.classList.add("is-open");

      const summary = document.createElement("button");
      summary.type = "button";
      summary.className = "services-faq-summary";
      summary.setAttribute("aria-expanded", index === 0 ? "true" : "false");

      const iconWrap = document.createElement("span");
      iconWrap.className = "services-faq-icon-wrap";
      iconWrap.setAttribute("aria-hidden", "true");

      const iconPlus = document.createElement("span");
      iconPlus.className = "services-faq-icon services-faq-icon-plus";
      iconPlus.innerHTML =
        '<svg viewBox="0 0 24 24" width="25" height="25" aria-hidden="true"><path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>';

      const iconMinus = document.createElement("span");
      iconMinus.className = "services-faq-icon services-faq-icon-minus";
      iconMinus.innerHTML =
        '<svg viewBox="0 0 24 24" width="25" height="25" aria-hidden="true"><path d="M5 12h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>';

      iconWrap.append(iconPlus, iconMinus);

      const question = document.createElement("span");
      question.className = "services-faq-question";
      question.textContent = item.question;

      summary.append(iconWrap, question);

      const answer = document.createElement("div");
      answer.className = "services-faq-answer";
      if (index !== 0) answer.hidden = true;

      const answerInner = document.createElement("div");
      answerInner.className = "services-faq-answer-inner";
      item.answerNodes.forEach((node) => {
        answerInner.append(node.cloneNode(true));
      });
      answer.append(answerInner);

      const answerId = `services-faq-answer-${index}`;
      answer.id = answerId;
      summary.setAttribute("aria-controls", answerId);

      entry.append(summary, answer);
      list.append(entry);
    });

    section.append(title, list);

    let node = heading.nextElementSibling;
    while (node && node.tagName !== "H2") {
      const toRemove = node;
      node = node.nextElementSibling;
      toRemove.remove();
    }

    prose.insertBefore(section, node);
    heading.remove();
    prose.dataset.servicesFaqReady = "true";
  }

  function prefersReducedMotion(): boolean {
    return window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  }

  function getAnswerHeight(answer: HTMLElement): number {
    const previousHeight = answer.style.height;
    answer.style.height = "auto";
    const height = answer.scrollHeight;
    answer.style.height = previousHeight;
    return height;
  }

  function finalizeOpenHeight(answer: HTMLElement) {
    answer.style.height = "auto";
  }

  function openFaqItem(item: HTMLElement) {
    const answer = item.querySelector<HTMLElement>(".services-faq-answer");
    const summary = item.querySelector<HTMLButtonElement>(".services-faq-summary");
    if (!answer || !summary) return;

    item.classList.add("is-open");
    summary.setAttribute("aria-expanded", "true");
    answer.hidden = false;

    if (prefersReducedMotion()) {
      answer.style.height = "auto";
      return;
    }

    const targetHeight = getAnswerHeight(answer);
    answer.style.height = "0px";

    requestAnimationFrame(() => {
      answer.style.height = `${targetHeight}px`;
    });

    const onEnd = (event: TransitionEvent) => {
      if (event.propertyName !== "height" || !item.classList.contains("is-open")) return;
      answer.removeEventListener("transitionend", onEnd);
      finalizeOpenHeight(answer);
    };

    answer.addEventListener("transitionend", onEnd);
    window.setTimeout(() => {
      if (item.classList.contains("is-open")) {
        finalizeOpenHeight(answer);
      }
    }, 500);
  }

  function closeFaqItem(item: HTMLElement): Promise<void> {
    const answer = item.querySelector<HTMLElement>(".services-faq-answer");
    const summary = item.querySelector<HTMLButtonElement>(".services-faq-summary");
    if (!answer || !summary) return Promise.resolve();

    item.classList.remove("is-open");
    summary.setAttribute("aria-expanded", "false");

    if (prefersReducedMotion() || answer.hidden) {
      answer.hidden = true;
      answer.style.height = "";
      return Promise.resolve();
    }

    const startHeight = getAnswerHeight(answer);
    answer.style.height = `${startHeight}px`;

    return new Promise((resolve) => {
      requestAnimationFrame(() => {
        answer.style.height = "0px";
      });

      const onEnd = (event: TransitionEvent) => {
        if (event.propertyName !== "height") return;
        answer.removeEventListener("transitionend", onEnd);
        answer.hidden = true;
        answer.style.height = "";
        resolve();
      };

      answer.addEventListener("transitionend", onEnd);
      window.setTimeout(() => {
        answer.hidden = true;
        answer.style.height = "";
        resolve();
      }, 500);
    });
  }

  function setupFaqAccordionInteractions(root: ParentNode) {
    const items = [...root.querySelectorAll<HTMLElement>(".services-faq-item")];
    if (!items.length) return;

    items.forEach((item) => {
      if (item.dataset.faqBound === "true") return;

      const summary = item.querySelector<HTMLButtonElement>(".services-faq-summary");
      const answer = item.querySelector<HTMLElement>(".services-faq-answer");
      if (!summary || !answer) return;

      if (item.classList.contains("is-open")) {
        answer.style.height = "auto";
      }

      summary.addEventListener("click", async () => {
        const isOpen = item.classList.contains("is-open");
        if (isOpen) {
          await closeFaqItem(item);
          return;
        }

        await Promise.all(
          items
            .filter((other) => other !== item && other.classList.contains("is-open"))
            .map((other) => closeFaqItem(other))
        );

        openFaqItem(item);
      });

      item.dataset.faqBound = "true";
    });
  }

  function setupServicesFaq() {
    const prose = document.querySelector<HTMLElement>(".prose");
    if (!prose) return;

    buildFaqAccordion(prose);
    setupFaqAccordionInteractions(prose);
  }

  setupServicesFaq();
  document.addEventListener("astro:page-load", setupServicesFaq);
</script>

<style is:global>
  .services-faq {
    margin-block: var(--space-xl) var(--space-lg);
    scroll-margin-top: calc(var(--space-md) + 4rem);
  }

  .services-faq-title {
    margin: 0 0 clamp(2rem, 4vw, 2.5rem);
    font-family: var(--font-heading);
    font-size: clamp(1.375rem, 1.1rem + 0.9vw, 1.875rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-align: center;
    color: var(--color-text);
  }

  .services-faq-list {
    display: grid;
    gap: 1.25rem;
  }

  .services-faq-item {
    border: none;
    border-radius: 3.75rem 0;
    background: #fff;
    box-shadow: 6px 6px 15px -6px rgb(0 0 0 / 0.24);
  }

  .services-faq-summary {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    min-height: 3.75rem;
    padding: 0.625rem 1.25rem;
    border: 0;
    background: transparent;
    cursor: pointer;
    text-align: left;
    font: inherit;
    transition: background-color 0.25s ease;
  }

  .services-faq-icon-wrap {
    position: relative;
    flex: 0 0 1.5625rem;
    width: 1.5625rem;
    height: 1.5625rem;
  }

  .services-faq-icon {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    transition:
      opacity 0.28s ease,
      transform 0.28s ease;
  }

  .services-faq-icon svg {
    display: block;
    width: 1.5625rem;
    height: 1.5625rem;
  }

  .services-faq-icon-plus {
    color: #898585;
    opacity: 1;
    transform: scale(1);
  }

  .services-faq-icon-minus {
    color: var(--color-text);
    opacity: 0;
    transform: scale(0.82);
  }

  .services-faq-item.is-open .services-faq-icon-plus {
    opacity: 0;
    transform: scale(0.82);
  }

  .services-faq-item.is-open .services-faq-icon-minus {
    opacity: 1;
    transform: scale(1);
  }

  .services-faq-question {
    flex: 1;
    padding: 0;
    font-family: var(--font-body);
    font-size: clamp(0.9375rem, 0.88rem + 0.2vw, 1.25rem);
    font-weight: 400;
    letter-spacing: 0.025em;
    line-height: 1.35;
    color: var(--color-text);
  }

  .services-faq-answer {
    overflow: hidden;
    height: 0;
    background: #fff;
    padding-inline: 1.875rem;
    padding-bottom: 0;
    transition:
      height 0.42s cubic-bezier(0.4, 0, 0.2, 1),
      padding-bottom 0.42s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .services-faq-item.is-open .services-faq-answer {
    height: auto;
    padding-bottom: 0.9375rem;
  }

  .services-faq-answer[hidden] {
    display: block !important;
    height: 0 !important;
    padding-bottom: 0 !important;
    visibility: hidden;
  }

  .services-faq-answer-inner {
    padding-bottom: 0.15rem;
    opacity: 0;
    transform: translateY(-0.4rem);
    transition:
      opacity 0.34s ease 0.06s,
      transform 0.42s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .services-faq-item.is-open .services-faq-answer-inner {
    opacity: 1;
    transform: translateY(0);
  }

  .services-faq-answer-inner p {
    margin: 0;
    padding-top: 0.15rem;
    font-family: var(--font-body);
    font-size: clamp(0.9375rem, 0.88rem + 0.15vw, 1rem);
    font-weight: 400;
    line-height: 1.7;
    color: var(--color-text);
  }

  .services-faq-answer-inner p + p {
    margin-top: 0.75rem;
  }

  .services-faq-item--peach .services-faq-summary {
    background: rgb(249 164 64 / 0.22);
  }

  .services-faq-item--mint .services-faq-summary {
    background: rgb(103 199 202 / 0.3);
  }

  .services-faq-item--pink .services-faq-summary {
    background: rgb(255 172 183 / 0.7);
  }

  .services-faq-item--taupe .services-faq-summary {
    background: rgb(198 141 133 / 0.46);
  }

  @media (max-width: 767px) {
    .services-faq-item {
      border-radius: 2.5rem 0;
    }

    .services-faq-summary {
      padding: 0.625rem 0.75rem;
      gap: 0.625rem;
    }

    .services-faq-icon-wrap {
      flex-basis: 1.25rem;
      width: 1.25rem;
      height: 1.25rem;
    }

    .services-faq-icon svg {
      width: 1.25rem;
      height: 1.25rem;
    }

    .services-faq-answer {
      padding-inline: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .services-faq-summary,
    .services-faq-icon,
    .services-faq-answer,
    .services-faq-answer-inner {
      transition: none;
    }

    .services-faq-answer-inner {
      opacity: 1;
      transform: none;
    }
  }
</style>
