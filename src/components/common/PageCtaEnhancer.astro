---
/**
 * Stylise les liens d'action isolés du contenu markdown en boutons CTA.
 */
---

<script>
  function isStandaloneCtaParagraph(element: Element): boolean {
    if (element.tagName !== "P" || element.classList.contains("page-cta")) {
      return false;
    }

    const link = element.querySelector("a");
    if (!link || element.querySelector("img")) return false;

    const text = element.textContent?.trim() ?? "";
    return text === link.textContent?.trim();
  }

  function enhancePageCtas(prose: HTMLElement) {
    prose.querySelectorAll("p").forEach((paragraph) => {
      if (!isStandaloneCtaParagraph(paragraph)) return;

      paragraph.classList.add("page-cta");

      const link = paragraph.querySelector("a");
      if (!link) return;

      const href = link.getAttribute("href") ?? "";
      if (href.startsWith("http") && !link.hasAttribute("target")) {
        link.target = "_blank";
        link.rel = "noopener noreferrer";
      }
    });
  }

  function setupPageCtas() {
    document.querySelectorAll<HTMLElement>(".prose").forEach((prose) => {
      if (prose.dataset.pageCtaReady === "true") return;

      enhancePageCtas(prose);
      prose.dataset.pageCtaReady = "true";
    });
  }

  setupPageCtas();
  document.addEventListener("astro:page-load", setupPageCtas);
</script>

<style is:global>
  .page-cta {
    margin-top: var(--space-md);
    text-align: center;
  }

  .page-cta a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.45rem;
    border-radius: 2.1875rem 0;
    background: var(--color-primary-strong);
    color: #fff;
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 400;
    text-decoration: none;
    transition:
      background var(--transition),
      transform var(--transition);
  }

  .page-cta a:hover {
    background: var(--color-primary-stronger);
    color: #fff;
    transform: translateY(-2px);
  }

  @media (max-width: 820px) {
    .page-cta a {
      font-size: 1.0625rem;
    }
  }
</style>
