---
/**
 * Section « Mes spécialités » : texte à gauche, photo à droite (comme la prod).
 */
---

<script>
  function extractImageParagraph(paragraph: Element): HTMLImageElement[] | null {
    if (paragraph.tagName !== "P") return null;

    const imgs = [...paragraph.querySelectorAll("img")];
    if (!imgs.length) return null;

    const clone = paragraph.cloneNode(true) as HTMLElement;
    clone.querySelectorAll("img").forEach((img) => img.remove());
    const leftover = clone.textContent?.replace(/\[/g, "").trim() ?? "";
    if (leftover) return null;

    return imgs;
  }

  function buildSpecialitesSplit(prose: HTMLElement) {
    const heading = prose.querySelector<HTMLElement>(
      'h2[id^="mes-spécialités"], h2[id^="mes-specialites"], h2[id^="my-special"]'
    );
    if (!heading || heading.dataset.specialitesReady === "true") return;

    const textNodes: Element[] = [];
    let imageParagraph: Element | null = null;
    let next = heading.nextElementSibling;

    while (next && next.tagName !== "H2") {
      const imgs = extractImageParagraph(next);
      if (imgs?.length === 1 && !imageParagraph) {
        imageParagraph = next;
        next = next.nextElementSibling;
        break;
      }

      textNodes.push(next);
      next = next.nextElementSibling;
    }

    if (!imageParagraph || !textNodes.length) return;

    const split = document.createElement("div");
    split.className = "page-split page-split-reverse specialites-split";

    const contentCol = document.createElement("div");
    contentCol.className = "page-split-content";
    contentCol.append(heading);
    textNodes.forEach((node) => contentCol.append(node));

    const imageCol = document.createElement("div");
    imageCol.className = "page-split-image";

    const imageInner = document.createElement("div");
    imageInner.className = "page-split-image-inner";

    const sourceImg = imageParagraph.querySelector("img");
    if (!sourceImg) return;

    const image = sourceImg.cloneNode(true) as HTMLImageElement;
    image.removeAttribute("width");
    image.removeAttribute("height");
    image.loading = "lazy";
    imageInner.append(image);
    imageCol.append(imageInner);

    split.append(contentCol, imageCol);
    imageParagraph.remove();
    prose.insertBefore(split, next);
    heading.dataset.specialitesReady = "true";
  }

  function setupSpecialitesSplit() {
    const prose = document.querySelector<HTMLElement>(".prose.prose-wide");
    if (!prose || prose.dataset.specialitesReady === "true") return;

    buildSpecialitesSplit(prose);
    if (prose.querySelector(".specialites-split")) {
      prose.dataset.specialitesReady = "true";
    }
  }

  setupSpecialitesSplit();
  document.addEventListener("astro:page-load", setupSpecialitesSplit);
</script>

<style is:global>
  .page-split {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    align-items: start;
    gap: clamp(1.5rem, 4vw, 3rem);
    margin-block: var(--space-md);
  }

  .page-split-content {
    max-width: none;
    margin: 0;
  }

  .page-split-content > * + * {
    margin-top: var(--space-sm);
  }

  .page-split-content h2 {
    margin-top: 0;
    text-align: center;
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }

  /* Même style que les sous-titres dans la colonne (ex. Anxiété hors split) */
  .page-split-content h3,
  .specialites-split ~ h3 {
    margin-top: var(--space-md);
    font-family: var(--font-body);
    font-size: clamp(1rem, 0.9rem + 0.35vw, 1.25rem);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-secondary-dark);
  }

  .page-split-content p,
  .page-split-content li,
  .specialites-split ~ p {
    color: var(--color-text);
    font-weight: 300;
    line-height: 1.7;
  }

  .page-split-image {
    position: sticky;
    top: calc(var(--space-md) + 4rem);
  }

  .specialites-split .page-split-image-inner {
    overflow: hidden;
    border-radius: 0 0 0 5rem;
  }

  .specialites-split .page-split-image-inner img {
    display: block;
    width: 100%;
    min-height: 18rem;
    object-fit: cover;
    object-position: center;
    margin: 0;
    border-radius: 0;
    box-shadow: none;
  }

  @media (max-width: 820px) {
    .page-split,
    .page-split-reverse {
      grid-template-columns: 1fr;
    }

    .page-split-image {
      position: static;
      order: -1;
    }

    .specialites-split .page-split-image-inner {
      max-width: 22rem;
      margin-inline: auto;
      border-radius: 0 0 0 3.75rem;
    }

    .specialites-split .page-split-image-inner img {
      max-height: 18rem;
    }
  }
</style>
