---
import { SITE, getSiteGlobal } from "@/site.config";
import { getLocaleFromPath } from "@/lib/i18n";
import { resolveSeoImagePath } from "@/lib/images";
import { localeToSchemaLanguage } from "@/lib/seo";
import { useTranslations } from "@/lib/translations";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: Date;
  modifiedTime?: Date;
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  image,
  type = "website",
  publishedTime,
  modifiedTime,
  noindex = false,
  structuredData,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE.url).href;
const locale = getLocaleFromPath(Astro.url.pathname);
const global = getSiteGlobal(locale);
function shorten(value: string, maxLength: number): string {
  if (value.length <= maxLength) return value;
  const shortened = value.slice(0, maxLength - 1).replace(/\s+\S*$/, "").trim();
  return `${shortened}…`;
}

const cleanTitle = title?.trim();
const fullTitleCandidate = cleanTitle
  ? `${cleanTitle} | ${SITE.name}`
  : global.defaultSeoTitle;
const fullTitle = shorten(fullTitleCandidate, 54);
const cleanDescription = shorten(
  description?.trim() || global.defaultSeoDescription,
  155
);
const ogImagePath = await resolveSeoImagePath(
  image || "/images/heroes/hero-accueil-desktop.png"
);
const ogImage = ogImagePath ? new URL(ogImagePath, SITE.url).href : undefined;
const t = useTranslations(locale);
const language = localeToSchemaLanguage(locale);
const sameAs = [global.instagramUrl, global.facebookUrl].filter(Boolean);
const personId = new URL("/#person", SITE.url).href;
const serviceId = new URL("/#professional-service", SITE.url).href;
const websiteId = new URL("/#website", SITE.url).href;
const webpageId = `${canonical}#webpage`;

const graph: Record<string, unknown>[] = [
  {
    "@type": "Person",
    "@id": personId,
    name: global.siteName,
    jobTitle:
      locale === "fr"
        ? "Psychologue clinicienne en ligne"
        : "Online clinical psychologist",
    url: SITE.url,
    email: global.email,
    telephone: global.phone,
    sameAs,
  },
  {
    "@type": "ProfessionalService",
    "@id": serviceId,
    name: global.siteName,
    description: global.defaultSeoDescription,
    url: SITE.url,
    email: global.email,
    telephone: global.phone,
    areaServed: global.area,
    availableLanguage: [language],
    sameAs,
    provider: { "@id": personId },
  },
  {
    "@type": "WebSite",
    "@id": websiteId,
    name: SITE.name,
    url: SITE.url,
    inLanguage: language,
    publisher: { "@id": personId },
  },
  {
    "@type": "WebPage",
    "@id": webpageId,
    url: canonical,
    name: fullTitle,
    description: cleanDescription,
    inLanguage: language,
    isPartOf: { "@id": websiteId },
    about: { "@id": serviceId },
  },
];

if (type === "article" && publishedTime) {
  graph.push({
    "@type": "BlogPosting",
    "@id": `${canonical}#article`,
    headline: cleanTitle || fullTitle,
    description: cleanDescription,
    image: ogImage,
    datePublished: publishedTime.toISOString(),
    dateModified: (modifiedTime || publishedTime).toISOString(),
    author: { "@id": personId },
    publisher: { "@id": personId },
    mainEntityOfPage: { "@id": webpageId },
    inLanguage: language,
  });
}

const extraStructuredData = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [...graph, ...extraStructuredData],
};
---

<title>{fullTitle}</title>
<meta name="description" content={cleanDescription} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
{
  SITE.googleSiteVerification && (
    <meta
      name="google-site-verification"
      content={SITE.googleSiteVerification}
    />
  )
}

<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={cleanDescription} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content={t.locale.og} />
{ogImage && <meta property="og:image" content={ogImage} />}
{
  type === "article" && publishedTime && (
    <meta
      property="article:published_time"
      content={publishedTime.toISOString()}
    />
  )
}
{
  type === "article" && modifiedTime && (
    <meta
      property="article:modified_time"
      content={modifiedTime.toISOString()}
    />
  )
}

<meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={cleanDescription} />
{ogImage && <meta name="twitter:image" content={ogImage} />}
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
