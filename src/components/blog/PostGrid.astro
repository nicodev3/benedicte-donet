---
import type { CollectionEntry } from "astro:content";
import SiteImage from "@/components/common/SiteImage.astro";
import { localizedPath, stripLocaleFromFilePath, type Locale } from "@/lib/i18n";
import { slugifyTag } from "@/lib/tags";
import { preventPunctuationWrap } from "@/lib/typography";
import { useTranslations } from "@/lib/translations";

interface Props {
  posts: CollectionEntry<"blog">[];
  locale: Locale;
}

const { posts, locale } = Astro.props;
const t = useTranslations(locale);

const formatCardDate = (date: Date) =>
  new Intl.DateTimeFormat(t.locale.date, {
    day: "2-digit",
    month: "2-digit",
    year: "numeric",
  }).format(date);
---

<div class="posts-grid">
  {
    posts.map((post) => {
      const slug = stripLocaleFromFilePath(post.filePath, post.id);
      const url = localizedPath(`/${slug}/`, locale);

      return (
        <article class="post-card">
          <header class="post-card-header">
            <h2 class="post-card-title">
              <a href={url}>{preventPunctuationWrap(post.data.title)}</a>
            </h2>
            <p class="post-card-meta">
              <time datetime={post.data.date.toISOString()}>
                {formatCardDate(post.data.date)}
              </time>
            </p>
          </header>
          {post.data.image && (
            <a href={url} class="post-card-media" tabindex="-1" aria-hidden="true">
              <SiteImage
                src={post.data.image}
                alt={post.data.imageAlt || post.data.title}
                width={450}
                height={320}
                widths={[450, 900]}
                sizes="(max-width: 700px) 90vw, 400px"
                loading="lazy"
              />
            </a>
          )}
          {post.data.excerpt && (
            <p class="post-card-excerpt">{post.data.excerpt}</p>
          )}
          {post.data.tags.length > 0 && (
            <ul class="post-card-tags">
              {post.data.tags.map((tag) => (
                <li>
                  <a href={localizedPath(`/blog/tag/${slugifyTag(tag)}/`, locale)}>{tag}</a>
                </li>
              ))}
            </ul>
          )}
          <a href={url} class="post-card-readmore">
            ~ {t.blog.readMore}
          </a>
        </article>
      );
    })
  }
</div>

<style>
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 1fr;
    align-items: stretch;
    gap: 1.875rem;
    padding-block: var(--space-xl);
  }

  .post-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    background: var(--color-bg);
    border: 2px solid var(--color-primary);
    border-top-left-radius: 120px;
    border-top-right-radius: 120px;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    padding: 70px 10px 0;
    text-align: center;
    height: 100%;
  }

  .post-card-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    /* 5 lignes de titre + date — hauteur fixe pour aligner les images */
    height: calc(1.25rem * 1.125 * 5 + 0.75rem + 1.25rem);
    flex-shrink: 0;
  }

  .post-card-title {
    margin: 0;
    flex: 0 1 auto;
    max-height: calc(1.25rem * 1.125 * 5);
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.125;
    letter-spacing: 0.025em;
  }

  .post-card-title a {
    color: var(--color-text);
    text-decoration: underline;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 5;
    overflow: hidden;
    line-height: 1.125;
    text-wrap: pretty;
  }

  .post-card-title a:hover {
    color: var(--color-primary-dark);
  }

  .post-card-meta {
    margin: 0;
    margin-top: auto;
    flex-shrink: 0;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 300;
    letter-spacing: 0.056em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: underline;
  }

  .post-card-media {
    display: block;
    width: 90%;
    margin-block: 0.625rem;
    text-decoration: none;
  }

  .post-card-media :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0;
    transition: opacity var(--transition);
  }

  .post-card-media:hover :global(img) {
    opacity: 0.2;
  }

  .post-card-excerpt {
    width: 100%;
    margin: 0;
    padding-inline: 1.25rem;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 300;
    line-height: 1.35;
    letter-spacing: 0.025em;
    text-align: left;
    color: var(--color-text);
    flex: 1;
  }

  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    width: 100%;
    margin: 0;
    padding-inline: 1.25rem;
    list-style: none;
  }

  .post-card-tags a {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.025em;
    color: var(--color-primary-dark);
    text-decoration: underline;
  }

  .post-card-tags a:hover {
    color: var(--color-text);
  }

  .post-card-readmore {
    align-self: flex-start;
    margin-top: auto;
    margin-bottom: 1.25rem;
    padding-inline: 1.25rem;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.0125em;
    color: var(--color-text);
    text-decoration: underline;
  }

  .post-card-readmore:hover {
    color: var(--color-primary-dark);
  }

  @media (max-width: 1024px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }

    .post-card-header {
      height: calc(1.625rem * 1.125 * 5 + 0.75rem + 1.25rem);
    }

    .post-card-title {
      font-size: 1.625rem;
      max-height: calc(1.625rem * 1.125 * 5);
    }

    .post-card-meta,
    .post-card-excerpt {
      font-size: 1rem;
    }
  }

  @media (max-width: 767px) {
    .posts-grid {
      grid-template-columns: 1fr;
      gap: 1.5625rem;
    }

    .post-card-header {
      height: auto;
      min-height: 5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .post-card-title a {
      display: inline;
      -webkit-line-clamp: unset;
      overflow: visible;
    }

    .post-card-title {
      font-size: 1.125rem;
      letter-spacing: 0.006em;
    }

    .post-card-meta {
      font-size: 0.8125rem;
    }

    .post-card-excerpt {
      font-size: 0.875rem;
    }

    .post-card-readmore {
      font-size: 0.9375rem;
    }
  }
</style>
