---
import { getOptimizedSrc } from "@/lib/images";
import { preventPunctuationWrap } from "@/lib/typography";

interface Props {
  title: string;
  date: Date;
  dateLocale: string;
  backgroundImage?: string;
  backgroundPosition?: string;
}

const {
  title,
  date,
  dateLocale,
  backgroundImage,
  backgroundPosition = "center right",
} = Astro.props;

const formattedDate = new Intl.DateTimeFormat(dateLocale, {
  day: "2-digit",
  month: "2-digit",
  year: "numeric",
}).format(date);

const desktopBg = await getOptimizedSrc(backgroundImage, { width: 1920 });
---

<section class="post-hero">
  <div
    class="post-hero-panel"
    style={{
      "--post-hero-bg": desktopBg ? `url(${desktopBg})` : "none",
      "--post-hero-bg-position": backgroundPosition,
    }}
  >
    <div class="post-hero-overlay" aria-hidden="true" />
    <div class="post-hero-content">
      <p class="post-hero-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </p>
      <h1>{preventPunctuationWrap(title)}</h1>
    </div>
  </div>
</section>

<style>
  .post-hero {
    padding-block: 0;
  }

  .post-hero-panel {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    min-height: 12.5rem;
    text-align: center;
    border-radius: 0 0 5rem 0;
    box-shadow: 3px 6px 15px rgba(0, 0, 0, 0.25);
    background-color: var(--color-bg-soft);
    background-image: var(--post-hero-bg);
    background-position: var(--post-hero-bg-position, center right);
    background-repeat: no-repeat;
    background-size: cover;
  }

  .post-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
    background: rgba(255, 255, 255, 0.51);
    pointer-events: none;
  }

  .post-hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5625rem;
    width: 100%;
    max-width: 52rem;
    padding: 3.125rem 1.5rem;
  }

  .post-hero-meta {
    margin: 0;
    font-family: var(--font-body);
    font-size: clamp(0.875rem, 0.8rem + 0.35vw, 1.125rem);
    font-weight: 300;
    letter-spacing: 0.056em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: underline;
  }

  .post-hero-content h1 {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 1.2rem + 1.8vw, 2.6875rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.2;
    color: var(--color-text);
  }

  @media (min-width: 768px) {
    .post-hero-panel {
      width: 100vw;
      margin-left: calc(50% - 50vw);
    }
  }

  @media (min-width: 1025px) {
    .post-hero-panel {
      background-attachment: fixed;
    }
  }

  @media (max-width: 767px) {
    .post-hero {
      padding-inline: var(--space-md);
    }

    .post-hero-panel {
      border-radius: 0 0 3.75rem 0;
      background-position: top center;
      background-attachment: scroll;
    }

    .post-hero-content {
      padding: 2.5rem 1rem;
      gap: 1.25rem;
    }
  }
</style>
