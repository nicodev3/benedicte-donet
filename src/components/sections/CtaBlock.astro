---
import Container from "@/components/common/Container.astro";
import Section from "@/components/common/Section.astro";
import Button from "@/components/common/Button.astro";
import SiteImage from "@/components/common/SiteImage.astro";
import { renderInlineRichText, splitRichParagraphs } from "@/lib/rich-text";

interface Props {
  title: string;
  text: string;
  ctaLabel: string;
  ctaUrl: string;
  image?: string;
  imageAlt?: string;
}

const {
  title,
  text,
  ctaLabel,
  ctaUrl,
  image,
  imageAlt = "Illustration des masterclass et programmes",
} = Astro.props;

const paragraphs = splitRichParagraphs(text);
---

<Section>
  <Container>
    <div class:list={["cta-grid", { "no-image": !image }]}>
      {
        image && (
          <div class="cta-image">
            <SiteImage
              src={image}
              alt={imageAlt}
              width={500}
              widths={[320, 420, 500]}
              sizes="(max-width: 820px) 100vw, 420px"
              loading="lazy"
            />
          </div>
        )
      }
      <div class="cta-content">
        <h2>{title}</h2>
        <div class="cta-body">
          {paragraphs.map((paragraph) => (
            <p set:html={renderInlineRichText(paragraph)} />
          ))}
        </div>
        <Button href={ctaUrl}>{ctaLabel}</Button>
      </div>
    </div>
  </Container>
</Section>

<style>
  .cta-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    align-items: center;
    gap: var(--space-xl);
  }

  .cta-grid.no-image {
    grid-template-columns: 1fr;
    max-width: var(--container-narrow);
    margin-inline: auto;
    text-align: center;
  }

  .cta-content h2 {
    margin-bottom: var(--space-md);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-primary-dark);
    font-weight: 400;
  }

  .cta-body :global(p + p) {
    margin-top: var(--space-sm);
  }

  .cta-body :global(p) {
    color: var(--color-text-soft);
    font-weight: 300;
  }

  .cta-content :global(.button) {
    margin-top: var(--space-md);
  }

  .cta-image {
    overflow: hidden;
    border-radius: 0 0 5.625rem 0;
  }

  .cta-image :global(img) {
    width: 100%;
    max-height: 420px;
    object-fit: cover;
    object-position: center top;
    margin-inline: auto;
  }

  @media (max-width: 820px) {
    .cta-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .cta-image {
      border-radius: 0 0 3.75rem 0;
      max-width: 22rem;
      margin-inline: auto;
    }
  }
</style>
