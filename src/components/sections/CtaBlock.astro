---
import Container from "@/components/common/Container.astro";
import Section from "@/components/common/Section.astro";
import Button from "@/components/common/Button.astro";
import SiteImage from "@/components/common/SiteImage.astro";

interface Props {
  title: string;
  text: string;
  ctaLabel: string;
  ctaUrl: string;
  image?: string;
  imageAlt?: string;
}

const {
  title,
  text,
  ctaLabel,
  ctaUrl,
  image,
  imageAlt = "Illustration des masterclass et programmes",
} = Astro.props;
---

<Section tone="muted">
  <Container>
    <div class:list={["cta-grid", { "no-image": !image }]}>
      {
        image && (
          <div class="cta-image">
            <SiteImage
              src={image}
              alt={imageAlt}
              width={700}
              widths={[350, 500, 700]}
              sizes="(max-width: 820px) 100vw, 420px"
              loading="lazy"
            />
          </div>
        )
      }
      <div class="cta-content">
        <h2>{title}</h2>
        <p>{text}</p>
        <Button href={ctaUrl} variant="secondary">{ctaLabel}</Button>
      </div>
    </div>
  </Container>
</Section>

<style>
  .cta-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    align-items: center;
    gap: var(--space-xl);
  }

  .cta-grid.no-image {
    grid-template-columns: 1fr;
    max-width: var(--container-narrow);
    margin-inline: auto;
    text-align: center;
  }

  .cta-content h2 {
    margin-bottom: var(--space-md);
  }

  .cta-content p {
    margin-bottom: var(--space-md);
    color: var(--color-text-soft);
  }

  .cta-image :global(img) {
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
    margin-inline: auto;
    max-height: 420px;
    object-fit: contain;
  }

  @media (max-width: 820px) {
    .cta-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
  }
</style>
