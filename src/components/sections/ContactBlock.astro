---
import Container from "@/components/common/Container.astro";
import Section from "@/components/common/Section.astro";
import SiteImage from "@/components/common/SiteImage.astro";
import { getOptimizedSrc } from "@/lib/images";
import { getSiteGlobal } from "@/site.config";
import { getLocaleFromPath } from "@/lib/i18n";
import { useTranslations } from "@/lib/translations";

const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const global = getSiteGlobal(locale);
const FORMSPREE_ENDPOINT = "https://formspree.io/f/xzdnepdb";
const formLabels =
  locale === "fr"
    ? {
        title: "Je prends RDV via message",
        lastName: "Nom de famille",
        firstName: "Prénom",
        email: "Email",
        phone: "Téléphone",
        message: "Votre demande, vos besoins...",
        submit: "J'envoie",
        success: "Merci ! Votre message a bien été envoyé.",
        error: "Une erreur est survenue. Réessayez ou contactez-moi par email.",
        sending: "Envoi…",
      }
    : {
        title: "Book by message",
        lastName: "Last name",
        firstName: "First name",
        email: "Email",
        phone: "Phone",
        message: "Your request, your needs...",
        submit: "Send",
        success: "Thank you! Your message has been sent.",
        error: "Something went wrong. Please try again or email me directly.",
        sending: "Sending…",
      };
const contactBackground = await getOptimizedSrc("/images/backgrounds/bg-contact.webp", {
  width: 1000,
  format: "webp",
  quality: 60,
});
---

<Section id="contact" lazyBg={contactBackground} lazyBgVar="--contact-bg">
  <Container>
    <div class="contact-grid">
      <div class="contact-info">
        <h2>{t.contactBlock.title}</h2>
        <ul class="contact-list">
          <li>
            <SiteImage class="contact-icon" src="/images/ui/icon-whatsapp.svg" alt="" />
            <a href={`tel:${global.phone.replace(/\s/g, "")}`}>{global.phone}</a>
          </li>
          <li>
            <SiteImage class="contact-icon" src="/images/ui/icon-gmail.svg" alt="" />
            <a href={`mailto:${global.email}`}>{global.email}</a>
          </li>
          {global.area && <li class="contact-area">{global.area}</li>}
        </ul>
      </div>

      <form
        class="contact-form"
        action={FORMSPREE_ENDPOINT}
        method="POST"
        data-contact-form
        data-success={formLabels.success}
        data-error={formLabels.error}
        data-sending={formLabels.sending}
        data-submit-label={formLabels.submit}
      >
        <h2>{formLabels.title}</h2>
        <div class="form-card">
          <input type="hidden" name="_subject" value={formLabels.title} />
          <div class="form-row">
            <label>
              <span>{formLabels.lastName}</span>
              <input
                type="text"
                name="lastName"
                autocomplete="family-name"
                placeholder={formLabels.lastName}
                required
              />
            </label>
            <label>
              <span>{formLabels.firstName}</span>
              <input
                type="text"
                name="firstName"
                autocomplete="given-name"
                placeholder={formLabels.firstName}
                required
              />
            </label>
          </div>
          <div class="form-row">
            <label>
              <span>{formLabels.email}</span>
              <input
                type="email"
                name="email"
                autocomplete="email"
                placeholder={formLabels.email}
                required
              />
            </label>
            <label>
              <span>{formLabels.phone}</span>
              <input
                type="tel"
                name="phone"
                autocomplete="tel"
                placeholder={formLabels.phone}
              />
            </label>
          </div>
          <label class="message-field">
            <span>{formLabels.message}</span>
            <textarea
              name="message"
              rows="4"
              placeholder={formLabels.message}
              required
            ></textarea>
          </label>
          <p class="form-status" data-form-status hidden></p>
          <button type="submit">{formLabels.submit}</button>
        </div>
      </form>
    </div>
  </Container>
</Section>

<script>
  function initContactForms() {
    document.querySelectorAll<HTMLFormElement>("[data-contact-form]").forEach((form) => {
      if (form.dataset.initialized === "true") return;
      form.dataset.initialized = "true";

      const statusEl = form.querySelector<HTMLElement>("[data-form-status]");
      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        const endpoint = form.action;
        if (!endpoint) return;

        const submitLabel = form.dataset.submitLabel || "Send";
        const sendingLabel = form.dataset.sending || "Sending…";
        const successMessage = form.dataset.success || "Thank you!";
        const errorMessage = form.dataset.error || "Something went wrong.";

        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = sendingLabel;
        }
        if (statusEl) {
          statusEl.hidden = true;
          statusEl.textContent = "";
          statusEl.removeAttribute("data-state");
        }

        try {
          const response = await fetch(endpoint, {
            method: "POST",
            body: new FormData(form),
            headers: { Accept: "application/json" },
          });

          if (!response.ok) throw new Error("Formspree error");

          form.reset();
          if (statusEl) {
            statusEl.hidden = false;
            statusEl.textContent = successMessage;
            statusEl.dataset.state = "success";
          }
        } catch {
          if (statusEl) {
            statusEl.hidden = false;
            statusEl.textContent = errorMessage;
            statusEl.dataset.state = "error";
          }
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = submitLabel;
          }
        }
      });
    });
  }

  initContactForms();
  document.addEventListener("astro:page-load", initContactForms);
</script>

<style>
  :global(.section#contact) {
    position: relative;
    overflow: hidden;
    width: calc(100vw - var(--space-md));
    margin-left: calc(50% - 50vw);
    padding-block: 1.25rem 2.5rem;
    border-radius: 0 0 5rem 0;
    box-shadow: 3px 6px 15px 1px rgba(0, 0, 0, 0.25);
    background-image: var(--contact-bg, none);
    background-position: center center;
    background-repeat: no-repeat;
    background-size: cover;
  }

  :global(.section#contact)::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(210, 241, 242, 0.53);
    pointer-events: none;
  }

  :global(.section#contact > .container) {
    position: relative;
    z-index: 1;
    max-width: 64.375rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    align-items: center;
    gap: 0;
  }

  .contact-info {
    justify-self: end;
    width: 100%;
    max-width: 25rem;
    padding-top: 3.125rem;
  }

  .contact-info h2 {
    margin: 0 0 var(--space-md);
    font-family: var(--font-body);
    font-size: 1.375rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0;
    color: var(--color-text);
  }

  .contact-form h2 {
    margin: 0 0 1.25rem;
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }

  .contact-form h2 {
    text-align: center;
  }

  .contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: 0.15625rem;
    color: var(--color-text);
  }

  .contact-list li {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .contact-list li + li {
    margin-top: 1.875rem;
  }

  .contact-list a {
    color: var(--color-text);
    text-underline-offset: 0.25rem;
  }

  .contact-icon {
    width: 1.8125rem;
    height: 1.8125rem;
    flex-shrink: 0;
  }

  .contact-area {
    margin-top: 1.875rem;
    padding-left: 0;
  }

  .contact-form {
    width: 100%;
    max-width: 25rem;
    justify-self: start;
  }

  .form-card {
    position: relative;
    padding: 2.5rem 1.875rem;
    border-radius: 5rem 0;
    background: rgba(255, 255, 255, 0.88);
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .form-row + .form-row {
    margin-top: 1.5625rem;
  }

  .form-card label {
    display: grid;
  }

  .form-card span {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .form-card input,
  .form-card textarea {
    width: 100%;
    border: 0;
    border-bottom: 1px solid rgba(198, 141, 133, 0.65);
    border-radius: 0;
    padding: 0.35rem 0.625rem;
    background: transparent;
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.0625rem;
    resize: vertical;
  }

  .form-card input::placeholder,
  .form-card textarea::placeholder {
    color: var(--color-text);
    opacity: 1;
  }

  .form-card input:focus,
  .form-card textarea:focus {
    border-bottom-color: var(--color-primary-strong);
  }

  .form-card input:focus-visible,
  .form-card textarea:focus-visible {
    outline: 2px solid var(--color-primary-dark);
    outline-offset: 2px;
  }

  .message-field {
    margin-top: 1.5625rem;
  }

  .form-status {
    margin: 1rem 0 0;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    letter-spacing: 0.04em;
    text-align: center;
    text-transform: none;
  }

  .form-status[data-state="success"] {
    color: #2f6b4f;
  }

  .form-status[data-state="error"] {
    color: #9b3b3b;
  }

  .form-card button:disabled {
    opacity: 0.7;
    cursor: wait;
  }

  .form-card button {
    display: block;
    min-width: 7rem;
    margin: 1.125rem auto 0;
    border: 0;
    border-radius: 5rem 0;
    padding: 0.625rem 2.1875rem;
    background: var(--color-button);
    color: var(--color-button-text);
    font-family: var(--font-body);
    font-size: 1.0625rem;
    letter-spacing: 0.08125rem;
    cursor: pointer;
  }

  .form-card button:hover {
    background: var(--color-button-hover);
    color: var(--color-button-text);
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      justify-items: center;
    }

    .contact-info {
      justify-self: center;
      text-align: center;
    }

    .contact-list li {
      justify-content: center;
    }

    .contact-area {
      padding-left: 0;
    }
  }

  @media (max-width: 520px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
