---
import Container from "@/components/common/Container.astro";
import Section from "@/components/common/Section.astro";
import Button from "@/components/common/Button.astro";
import SiteImage from "@/components/common/SiteImage.astro";
import { Sparkles } from "@lucide/astro";
import { renderInlineRichText, splitRichParagraphs } from "@/lib/rich-text";

interface Props {
  title: string;
  text: string;
  ctaLabel?: string;
  ctaUrl?: string;
  image?: string;
  imageAlt?: string;
  reverse?: boolean;
  tone?: "default" | "soft" | "muted";
  variant?: "default" | "intro" | "online";
}

const {
  title,
  text,
  ctaLabel,
  ctaUrl,
  image,
  imageAlt = "Illustration de l'accompagnement psychologique",
  reverse = false,
  tone = "default",
  variant = "default",
} = Astro.props;

const paragraphs = splitRichParagraphs(text);
const isIntro = variant === "intro";
const isOnline = variant === "online";
const isRich = isIntro || isOnline;
const imageFirst = isIntro || reverse;
---

<Section {tone}>
  <Container>
    <div
      class:list={[
        "ti-grid",
        {
          reverse: reverse && !isIntro && !isOnline,
          "no-image": !image,
          intro: isIntro,
          online: isOnline,
        },
      ]}
    >
      {
        image && imageFirst && (
          <div class="ti-image">
            <SiteImage
              src={image}
              alt={imageAlt}
              width={352}
              widths={[200, 256, 352]}
              sizes="(max-width: 820px) 255px, 352px"
              loading="lazy"
            />
          </div>
        )
      }
      <div class="ti-content">
        <h2>{title}</h2>
        {
          isRich ? (
            <div class="ti-body">
              {paragraphs.map((paragraph) => (
                <p set:html={renderInlineRichText(paragraph)} />
              ))}
            </div>
          ) : (
            <p>{text}</p>
          )
        }
        {
          ctaLabel && ctaUrl && (
            isRich ? (
              <a
                class="ti-cta"
                href={ctaUrl}
                {...ctaUrl.startsWith("http")
                  ? { target: "_blank", rel: "noopener noreferrer" }
                  : {}}
              >
                <span>{ctaLabel}</span>
                <Sparkles size={32} aria-hidden="true" />
              </a>
            ) : (
              <Button href={ctaUrl} variant="outline">
                {ctaLabel}
              </Button>
            )
          )
        }
      </div>
      {
        image && !imageFirst && (
          <div class="ti-image">
            <SiteImage
              src={image}
              alt={imageAlt}
              width={500}
              widths={[320, 432, 500]}
              sizes="(max-width: 820px) 90vw, 432px"
              loading="lazy"
            />
          </div>
        )
      }
    </div>
  </Container>
</Section>

<style>
  .ti-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    align-items: center;
    gap: var(--space-xl);
  }

  .ti-grid.intro {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.35fr);
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3.75rem);
    padding-block: clamp(2.5rem, 5vw, 3.75rem);
  }

  .ti-grid.online {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    align-items: stretch;
    gap: clamp(1.5rem, 4vw, 3rem);
    padding-block: clamp(2.5rem, 5vw, 3.75rem);
  }

  .ti-grid.no-image {
    grid-template-columns: 1fr;
    max-width: var(--container-narrow);
    margin-inline: auto;
    text-align: center;
  }

  .ti-grid.reverse .ti-content {
    order: 2;
  }

  .ti-content h2 {
    margin-bottom: var(--space-md);
  }

  .ti-content > p {
    margin-bottom: var(--space-md);
    color: var(--color-text-soft);
  }

  .ti-grid.intro .ti-content {
    text-align: center;
  }

  .ti-grid.intro .ti-content h2,
  .ti-grid.online .ti-content h2 {
    font-family: var(--font-heading);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-primary-dark);
    margin-bottom: clamp(1.25rem, 2.5vw, 1.875rem);
  }

  .ti-grid.online .ti-content {
    text-align: start;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ti-grid.online .ti-image {
    overflow: hidden;
    border-radius: 1.25rem 0 0 6.25rem;
    min-height: 18rem;
  }

  .ti-grid.online .ti-image :global(img) {
    width: 100%;
    height: 100%;
    min-height: 18rem;
    max-height: none;
    object-fit: cover;
    object-position: center;
    border-radius: 0;
    box-shadow: none;
    margin-inline: 0;
  }

  .ti-content .ti-body :global(p) {
    text-align: start;
    color: var(--color-text);
    font-weight: 300;
    line-height: 1.7;
    margin-block: 0;
  }

  .ti-image :global(img) {
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
    margin-inline: auto;
  }

  .ti-grid.intro .ti-image {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .ti-grid.intro .ti-image :global(img) {
    width: 70%;
    max-width: 22rem;
    border-radius: 0;
    box-shadow: none;
  }

  .ti-cta {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    width: fit-content;
    gap: 0.75rem;
    margin-top: var(--space-md);
    padding: 0.75rem 1.45rem;
    border-radius: 2.1875rem 0;
    background: var(--color-button);
    color: var(--color-button-text);
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 400;
    text-decoration: none;
    transition:
      background var(--transition),
      transform var(--transition);
  }

  .ti-grid.intro .ti-cta {
    align-self: center;
  }

  .ti-cta:hover {
    background: var(--color-button-hover);
    color: var(--color-button-text);
    transform: translateY(-2px);
  }

  .ti-cta img {
    width: 2rem;
    height: auto;
    flex-shrink: 0;
  }

  .ti-cta :global(svg) {
    flex-shrink: 0;
  }

  @media (max-width: 820px) {
    .ti-grid,
    .ti-grid.reverse,
    .ti-grid.intro,
    .ti-grid.online {
      grid-template-columns: 1fr;
      padding-block: var(--space-xl);
    }

    .ti-grid.reverse .ti-content {
      order: 0;
    }

    .ti-grid.intro .ti-image :global(img) {
      width: min(70%, 16rem);
    }

    .ti-grid.online .ti-image {
      border-radius: 1rem 0 0 3.75rem;
      max-width: 22rem;
      margin-inline: auto;
    }

    .ti-grid.online .ti-image :global(img) {
      max-height: 18rem;
    }
  }
</style>
