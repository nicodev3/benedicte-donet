---
import { DEFAULT_LOCALE, type Locale } from "@/lib/i18n";
import { getOptimizedImage } from "@/lib/images";

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? DEFAULT_LOCALE;

const copy =
  locale === "en"
    ? {
        title: "Online psychologist",
        subtitle: "My services",
      }
    : {
        title: "Psychologue en visio",
        subtitle: "Mes services",
      };

const backgroundImage = "/images/heroes/hero-services.jpg";
const heroImage = await getOptimizedImage(backgroundImage, {
  widths: [414, 640, 828, 1200],
  format: "webp",
  quality: 65,
});
---

<section class="services-hero">
  <div class="services-hero-panel">
    {
      heroImage && (
        <img
          class="services-hero-bg"
          src={heroImage.src}
          srcset={heroImage.srcset}
          sizes="100vw"
          alt={
            locale === "en"
              ? "Dried flowers illustrating online psychology services"
              : "Fleurs séchées illustrant les services de psychologie en ligne"
          }
          width={Number(heroImage.attributes.width || 828)}
          height={Number(heroImage.attributes.height || 1104)}
          loading="eager"
          fetchpriority="high"
          decoding="sync"
        />
      )
    }
    <div class="services-hero-overlay" aria-hidden="true" />
    <div class="services-hero-content">
      <h1 class="services-hero-eyebrow">{copy.title}</h1>
      <p class="services-hero-title">{copy.subtitle}</p>
    </div>
  </div>
</section>

<style>
  .services-hero {
    padding-block: 0;
  }

  .services-hero-panel {
    position: relative;
    overflow: hidden;
    min-height: clamp(18rem, 24vw, 26rem);
    border-radius: 0 0 5rem 0;
    box-shadow: 3px 6px 15px rgba(0, 0, 0, 0.25);
    background-color: var(--color-bg-muted);
  }

  .services-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: left bottom;
    filter: saturate(0.85) brightness(1.05);
  }

  .services-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
    background:
      linear-gradient(
        105deg,
        rgb(255 255 255 / 0.42) 0%,
        rgb(255 251 249 / 0.78) 38%,
        rgb(255 251 249 / 0.94) 62%,
        rgb(255 251 249 / 0.97) 100%
      );
    pointer-events: none;
  }

  .services-hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    min-height: inherit;
    padding: clamp(2.25rem, 4.5vw, 3.5rem) clamp(1.25rem, 4vw, 3rem);
  }

  .services-hero-eyebrow {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.375rem, 1rem + 1.4vw, 2.6875rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1.15;
    text-align: center;
    text-wrap: balance;
    color: var(--color-text);
    text-shadow: 0 1px 18px rgb(255 255 255 / 0.95);
  }

  .services-hero-title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.375rem, 1rem + 1.1vw, 2.125rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.15;
    text-align: center;
    text-wrap: balance;
    color: var(--color-text);
    text-shadow: 0 1px 14px rgb(255 255 255 / 0.9);
  }

  @media (min-width: 768px) {
    .services-hero-panel {
      width: calc(100vw - var(--space-md));
      margin-left: calc(50% - 50vw);
    }
  }

  @media (max-width: 767px) {
    .services-hero {
      padding-inline: var(--space-md);
    }

    .services-hero-panel {
      min-height: auto;
      border-radius: 0 0 3.75rem 0;
    }

    .services-hero-bg {
      object-position: center bottom;
    }

    .services-hero-overlay {
      background: linear-gradient(
        180deg,
        rgb(255 251 249 / 0.72) 0%,
        rgb(255 251 249 / 0.94) 55%,
        rgb(255 251 249 / 0.98) 100%
      );
    }
  }
</style>
