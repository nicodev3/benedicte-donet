---
import Container from "@/components/common/Container.astro";
import Section from "@/components/common/Section.astro";
import Button from "@/components/common/Button.astro";
import { getGlobalSettings } from "@/lib/settings";
import { getLocaleFromPath } from "@/lib/i18n";
import { useTranslations } from "@/lib/translations";

/**
 * La newsletter WordPress utilisait un formulaire embarqué.
 * En attendant un endpoint dédié (ou un service type Brevo/Mailerlite),
 * on renvoie vers un contact email — voir docs/redirects.md.
 */
const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const global = await getGlobalSettings(locale);
---

<Section tone="muted">
  <Container narrow>
    <div class="newsletter">
      <h2>{t.newsletter.title}</h2>
      <p>{t.newsletter.text}</p>
      <Button
        href={`mailto:${global.email}?subject=${encodeURIComponent(t.newsletter.emailSubject)}`}
        variant="secondary"
      >
        {t.newsletter.cta}
      </Button>
    </div>
  </Container>
</Section>

<style>
  .newsletter {
    text-align: center;
  }

  .newsletter h2 {
    margin-bottom: var(--space-sm);
  }

  .newsletter p {
    margin-bottom: var(--space-md);
    color: var(--color-text-soft);
  }
</style>
