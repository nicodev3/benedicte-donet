---
import SiteImage from "@/components/common/SiteImage.astro";
import { productUrl, type MasterclassProduct } from "@/lib/masterclass-products";
import { DEFAULT_LOCALE, type Locale } from "@/lib/i18n";

interface Props {
  products: MasterclassProduct[];
  locale?: Locale;
}

const { products, locale = DEFAULT_LOCALE } = Astro.props;
---

<ul class="products-grid">
  {
    products.map((product) => {
      const url = productUrl(product.slug, locale);

      return (
      <li class="product-card">
        <a class="product-card-link" href={url}>
          <SiteImage
            src={product.image}
            alt={product.imageAlt}
            width={600}
            widths={[300, 450, 600]}
            sizes="(max-width: 640px) 100vw, 280px"
            loading="lazy"
            class="product-card-image"
          />
          <h3 class="product-card-title">
            {product.title}
            {product.subtitle && (
              <>
                <br />
                {product.subtitle}
              </>
            )}
          </h3>
          <p class="product-card-price">{product.price}</p>
        </a>
        <a class="product-card-button" href={url}>
          {product.ctaLabel}
        </a>
      </li>
      );
    })
  }
</ul>

<style>
  .products-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.625rem 4.0625rem;
    list-style: none;
    margin: var(--space-md) auto 0;
    padding: 0;
    max-width: 56rem;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.5rem 1.875rem 1.875rem;
    background: rgb(198 141 133 / 0.09);
    box-shadow: 3px 3px 12px rgb(0 0 0 / 0.3);
  }

  .product-card-link {
    display: block;
    width: 100%;
    color: inherit;
    text-decoration: none;
  }

  .product-card-link:hover {
    color: inherit;
  }

  .product-card-image :global(img) {
    width: 100%;
    height: auto;
    margin: 0 0 1.25rem;
    border-radius: 0;
  }

  .product-card-title {
    margin: 0 0 0.625rem;
    font-family: var(--font-body);
    font-size: clamp(1rem, 0.85rem + 0.7vw, 1.875rem);
    font-weight: 400;
    line-height: 1.35;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-secondary);
  }

  .product-card-price {
    margin: 0;
    font-family: var(--font-body);
    font-size: clamp(0.9375rem, 0.85rem + 0.35vw, 1.125rem);
    font-weight: 400;
    letter-spacing: 0.0375em;
    color: #746666;
  }

  .product-card-button {
    display: inline-block;
    margin-top: 0.9375rem;
    padding: 0.9375rem 1.5625rem;
    border-radius: 5rem 0;
    background: var(--color-accent);
    color: #fff;
    font-family: var(--font-body);
    font-size: clamp(0.9375rem, 0.85rem + 0.35vw, 1.25rem);
    font-weight: 500;
    letter-spacing: 0.025em;
    text-decoration: none;
    transition:
      background var(--transition),
      transform var(--transition);
  }

  .product-card-button:hover {
    background: #ff96a5;
    color: #fff;
    transform: translateY(-2px);
  }

  @media (max-width: 1024px) {
    .products-grid {
      gap: 2.5rem 1.25rem;
    }

    .product-card-title,
    .product-card-price,
    .product-card-button {
      font-size: 1rem;
    }
  }

  @media (max-width: 640px) {
    .products-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      max-width: 28rem;
    }

    .product-card {
      padding: 2rem 1.25rem 1.5rem;
    }

    .product-card-title,
    .product-card-price,
    .product-card-button {
      font-size: 0.9375rem;
    }
  }
</style>
