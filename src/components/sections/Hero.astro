---
import { getImage } from "astro:assets";
import { resolveImage } from "@/lib/images";
import doubleEtoiles from "@/assets/images/wp/double-etoiles.svg";

interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  backgroundImage: string;
  backgroundImageMobile?: string;
  ctaLabel: string;
  ctaUrl: string;
}

const {
  eyebrow,
  title,
  subtitle,
  backgroundImage,
  backgroundImageMobile,
  ctaLabel,
  ctaUrl,
} = Astro.props;

const isExternal = ctaUrl.startsWith("http");
const desktop = resolveImage(backgroundImage);
const mobile = resolveImage(backgroundImageMobile ?? backgroundImage);
const desktopBg = desktop
  ? (await getImage({ src: desktop, width: 1920 })).src
  : backgroundImage.startsWith("/images/")
    ? backgroundImage
    : undefined;
const mobileBg = mobile
  ? (await getImage({ src: mobile, width: 900 })).src
  : (backgroundImageMobile ?? backgroundImage).startsWith("/images/")
    ? (backgroundImageMobile ?? backgroundImage)
    : undefined;
---

<section class="hero">
  <div class="hero-panel" data-hero-panel>
    {
      (desktopBg || mobileBg) && (
        <div class="hero-backdrop" aria-hidden="true">
          <picture>
            {mobileBg && (
              <source media="(max-width: 767px)" srcset={mobileBg} />
            )}
            {desktopBg && (
              <img
                class="hero-backdrop-img"
                src={desktopBg}
                alt=""
                loading="eager"
                decoding="async"
              />
            )}
          </picture>
        </div>
      )
    }
    <div class="hero-overlay" aria-hidden="true" />
    <div class="hero-content">
      {eyebrow && <p class="hero-eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="hero-subtitle">{subtitle}</p>
      <a
        class="hero-cta"
        href={ctaUrl}
        {...isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {}}
      >
        <span>{ctaLabel}</span>
        <img src={doubleEtoiles.src} alt="" width="41" height="34" aria-hidden="true" />
      </a>
    </div>
  </div>
</section>

<script>
  function setupHeroFixedBackground() {
    const panel = document.querySelector<HTMLElement>("[data-hero-panel]");
    const img = panel?.querySelector<HTMLImageElement>(".hero-backdrop-img");
    if (!panel || !img) return;

    const desktopMq = window.matchMedia("(min-width: 768px)");
    const reducedMotionMq = window.matchMedia("(prefers-reduced-motion: reduce)");

    let ticking = false;

    const update = () => {
      if (!desktopMq.matches || reducedMotionMq.matches) {
        img.style.top = "";
        panel.classList.remove("hero-parallax-active");
        return;
      }

      panel.classList.add("hero-parallax-active");
      img.style.top = `${-panel.getBoundingClientRect().top}px`;
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(() => {
          update();
          ticking = false;
        });
      }
    };

    update();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", update, { passive: true });
    desktopMq.addEventListener("change", update);
    reducedMotionMq.addEventListener("change", update);
  }

  setupHeroFixedBackground();
</script>

<style>
  .hero {
    padding-block: 0;
  }

  .hero-panel {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
    border-radius: 0 0 5rem 0;
    box-shadow: 3px 6px 15px rgba(0, 0, 0, 0.25);
    background-color: var(--color-bg-soft);
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-backdrop picture,
  .hero-backdrop-img {
    display: block;
  }

  .hero-backdrop-img {
    position: absolute;
    top: 0;
    left: 50%;
    width: 100vw;
    min-width: 100%;
    height: 100%;
    max-width: none;
    transform: translateX(-50%);
    object-fit: cover;
    object-position: center right;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
    background: rgba(255, 255, 255, 0.8);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5625rem;
    width: 100%;
    padding: 3.125rem 1.5rem;
  }

  .hero-eyebrow {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.125rem, 1rem + 0.5vw, 1.5625rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }

  .hero-content h1 {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 1.2rem + 1.8vw, 2.6875rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.2;
    color: var(--color-text);
  }

  .hero-subtitle {
    margin: 0;
    max-width: 36rem;
    font-family: var(--font-heading);
    font-size: clamp(1rem, 0.9rem + 0.45vw, 1.5625rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1.45;
    color: var(--color-text);
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.45rem;
    border-radius: 2.1875rem 0;
    background: var(--color-primary-strong);
    color: #fff;
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 400;
    text-decoration: none;
    transition:
      background var(--transition),
      transform var(--transition);
  }

  .hero-cta:hover {
    background: var(--color-primary-stronger);
    transform: translateY(-2px);
  }

  .hero-cta img {
    width: 2rem;
    height: auto;
    flex-shrink: 0;
  }

  /* Desktop : pleine largeur viewport, marge à droite pour l’ombre */
  @media (min-width: 768px) {
    .hero-panel {
      width: calc(100vw - var(--space-md));
      margin-left: calc(50% - 50vw);
    }

    .hero-panel.hero-parallax-active .hero-backdrop-img {
      height: 100vh;
    }
  }

  @media (max-width: 767px) {
    .hero {
      padding-inline: var(--space-md);
    }

    .hero-panel {
      border-radius: 0 0 3.75rem 0;
    }

    .hero-backdrop-img {
      left: 0;
      width: 100%;
      transform: none;
      object-position: top center;
    }

    .hero-content {
      padding: 2.5rem 1rem;
      gap: 1.25rem;
    }

    .hero-cta {
      font-size: 1.0625rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-backdrop-img {
      height: 100%;
    }
  }
</style>
