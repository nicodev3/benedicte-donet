---
import Container from "@/components/common/Container.astro";
import Button from "@/components/common/Button.astro";

interface Props {
  title: string;
  subtitle: string;
  image?: string;
  ctaLabel: string;
  ctaUrl: string;
}

const { title, subtitle, image, ctaLabel, ctaUrl } = Astro.props;
---

<section class="hero">
  <Container>
    <div class="hero-grid">
      <div class="hero-content">
        <h1>{title}</h1>
        <p class="hero-subtitle">{subtitle}</p>
        <Button href={ctaUrl}>{ctaLabel}</Button>
      </div>
      {
        image && (
          <div class="hero-image">
            <img
              src={image}
              alt="Bénédicte Donet, psychologue en ligne"
              width="480"
              height="480"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        )
      }
    </div>
  </Container>
</section>

<style>
  .hero {
    background: linear-gradient(
      160deg,
      var(--color-bg-soft) 0%,
      #fff 70%
    );
    padding-block: var(--space-2xl);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    align-items: center;
    gap: var(--space-xl);
  }

  .hero-subtitle {
    margin-block: var(--space-md);
    font-size: var(--text-xl);
    color: var(--color-text-soft);
    font-family: var(--font-heading);
  }

  .hero-image img {
    border-radius: var(--radius-md);
    margin-inline: auto;
  }

  @media (max-width: 820px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-image {
      order: -1;
    }

    .hero-image img {
      max-width: 320px;
    }
  }
</style>
