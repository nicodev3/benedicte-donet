---
import { Sparkles } from "@lucide/astro";
import { getOptimizedSrc } from "@/lib/images";

interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  backgroundImage: string;
  backgroundImageMobile?: string;
  backgroundPosition?: string;
  ctaLabel?: string;
  ctaUrl?: string;
  subtitleFirst?: boolean;
}

const {
  eyebrow,
  title,
  subtitle,
  backgroundImage,
  backgroundImageMobile,
  backgroundPosition = "center right",
  ctaLabel,
  ctaUrl,
  subtitleFirst = false,
} = Astro.props;

const showCta = Boolean(ctaLabel && ctaUrl);
const isExternal = ctaUrl?.startsWith("http") ?? false;

const desktopBg = await getOptimizedSrc(backgroundImage, { width: 1920 });
const mobileBg = await getOptimizedSrc(backgroundImageMobile ?? backgroundImage, {
  width: 1920,
});
---

<section class="hero">
  <div
    class="hero-panel"
    style={{
      "--hero-bg-desktop": desktopBg ? `url(${desktopBg})` : "none",
      "--hero-bg-mobile": mobileBg ? `url(${mobileBg})` : "none",
      "--hero-bg-position": backgroundPosition,
    }}
  >
    <div class="hero-overlay" aria-hidden="true" />
    <div class="hero-content">
      {eyebrow && <p class="hero-eyebrow">{eyebrow}</p>}
      {
        subtitleFirst ? (
          <>
            <p class="hero-subtitle">{subtitle}</p>
            <h1>{title}</h1>
          </>
        ) : (
          <>
            <h1>{title}</h1>
            <p class="hero-subtitle">{subtitle}</p>
          </>
        )
      }
      {
        showCta && ctaUrl && (
          <a
            class="hero-cta"
            href={ctaUrl}
            {...isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {}}
          >
            <span>{ctaLabel}</span>
            <Sparkles size={32} aria-hidden="true" />
          </a>
        )
      }
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: 0;
  }

  .hero-panel {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    min-height: 12.5rem;
    text-align: center;
    border-radius: 0 0 5rem 0;
    box-shadow: 3px 6px 15px rgba(0, 0, 0, 0.25);
    background-color: var(--color-bg-soft);
    background-image: var(--hero-bg-mobile, var(--hero-bg-desktop));
    background-position: var(--hero-bg-position, center right);
    background-repeat: no-repeat;
    background-size: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
    background: rgba(255, 255, 255, 0.51);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5625rem;
    width: 100%;
    padding: 3.125rem 1.5rem;
  }

  .hero-eyebrow {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.125rem, 1rem + 0.5vw, 1.5625rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }

  .hero-content h1 {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 1.2rem + 1.8vw, 2.6875rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.2;
    color: var(--color-text);
  }

  .hero-subtitle {
    margin: 0;
    max-width: 36rem;
    font-family: var(--font-heading);
    font-size: clamp(1rem, 0.9rem + 0.45vw, 1.5625rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1.45;
    color: var(--color-text);
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.45rem;
    border-radius: 2.1875rem 0;
    background: var(--color-primary-strong);
    color: #fff;
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 400;
    text-decoration: none;
    transition:
      background var(--transition),
      transform var(--transition);
  }

  .hero-cta:hover {
    background: var(--color-primary-stronger);
    transform: translateY(-2px);
  }

  .hero-cta :global(svg) {
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .hero-panel {
      width: calc(100vw - var(--space-md));
      margin-left: calc(50% - 50vw);
      background-image: var(--hero-bg-desktop);
    }
  }

  @media (min-width: 1025px) {
    .hero-panel {
      background-attachment: fixed;
    }
  }

  @media (max-width: 767px) {
    .hero {
      padding-inline: var(--space-md);
    }

    .hero-panel {
      border-radius: 0 0 3.75rem 0;
      background-position: top center;
      background-attachment: scroll;
    }

    .hero-content {
      padding: 2.5rem 1rem;
      gap: 1.25rem;
    }

    .hero-cta {
      font-size: 1.0625rem;
    }
  }
</style>
